[Desktop Entry]
Version=1.0
Type=Application
Name=The Mechanist
Comment=Launch The Mechanist civic-industrial survival simulation
Exec=sh -c 'APPDIR="$(dirname "$(readlink -f "$1")")"; cd "$APPDIR"; exec ./run_linux.sh' launcher %k
Path=
Icon=the-mechanist
Terminal=true
Categories=Game;StrategyGame;
StartupNotify=true
