    java.util.List<String> bodyInfopediaLines(String entry) {
        ArrayList<String> lines = new ArrayList<>();
        switch(entry) {
            case "Body Overview":
                lines.add("Body-state overview");
                lines.add("Tracked parts include head, torso, hips, upper/lower arms, hands, fingers, upper/lower legs, and feet. Each part has local health derived from endurance.");
                lines.add("Current body pressure: wounds " + wounds + ", bleeding " + bleeding + ", infection risk " + infectionRisk + ", pain " + pain + ".");
                break;
            case "Crippled Legs":
                lines.add("Mobility injury reference");
                lines.add("Crippled legs and feet increase movement time cost, turning injury into lost time and therefore into survival pressure.");
                lines.add("Current crippled leg/foot count: " + crippledLegCount() + ".");
                break;
            case "Crippled Arms and Hands":
                lines.add("Tool and weapon injury reference");
                lines.add("Crippled arms, hands, and fingers penalize weapon and tool use. Severe arm damage can prevent carried weapon attacks.");
                lines.add("Current crippled arm/hand count: " + crippledArmCount() + ".");
                break;
            case "Bleeding":
                lines.add("Bleeding reference");
                lines.add("Bleeding creates hourly wound/fatigue pressure until bandaged or treated.");
                lines.add("Current bleeding: " + bleeding + ". Bandages and medicae supplies are the intended first answers.");
                break;
            case "Pain":
                lines.add("Pain reference");
                lines.add("Pain imposes action friction and decays slowly. Stimulants may keep the character upright but are not wound treatment.");
                lines.add("Current pain: " + pain + ".");
                break;
            case "Infection Risk":
                lines.add("Infection-risk reference");
                lines.add("Infection risk can worsen if injuries are not treated with antiseptic or better medicae supplies.");
                lines.add("Current infection risk: " + infectionRisk + ".");
                break;
            default:
                lines.add("Incapacitation reference");
                lines.add("Severe accumulated damage, body/head trauma, and exhaustion can push the character out of useful action.");
                lines.add("Purpose: body systems make injury a continuing operational problem, not a single red number.");
                break;
        }
        return lines;
    }

    java.util.List<String> medicalInfopediaLines(String entry) {
        ArrayList<String> lines = new ArrayList<>();
        switch(entry) {
            case "Medical Overview":
                lines.add("Medical treatment overview");
                lines.add("Medical play is divided between carried supplies, field stabilization, paid doctors/clinics, and later prosthetic or augmentic repair.");
                lines.add("Current state: wounds " + wounds + ", bleeding " + bleeding + ", infection risk " + infectionRisk + ", fatigue " + fatigue + ", pain " + pain + ".");
                break;
            case "Bandages and Field Dressings":
                lines.add("Bleeding-control reference");
                lines.add("Bandages and field dressings reduce bleeding and one wound. They are the best first response after knives, claws, bullets, and poor decisions.");
                break;
            case "Medkits and Medicae Supplies":
                lines.add("General medicae item reference");
                lines.add("Medkits and medicae supplies provide stronger treatment: bleeding, wounds, infection risk, fatigue, pain, and the worst body part can all improve slightly.");
                break;
            case "Antiseptic":
                lines.add("Infection-control reference");
                lines.add("Antiseptic reduces infection risk without pretending to fix structural damage. Use it after dirty wounds, sewer work, or mutant unpleasantness.");
                break;
            case "Splints":
                lines.add("Limb-stabilization reference");
                lines.add("Splints stabilize the worst limb enough to reduce mobility/tool collapse, especially after leg or arm trauma.");
                break;
            case "Injectors":
                lines.add("Injector reference");
                lines.add("Injectors reduce fatigue and pain with minor wound relief. Useful, portable, and absolutely not a license to sprint through a gunfight twice.");
                break;
            case "Doctors and Clinics":
                lines.add("Paid treatment reference");
                lines.add("Doctors and clinics are the intended vendor/service path for deeper repair, prosthetics, augmentics, and high-quality medical work.");
                break;
            default:
                lines.add("Prosthetics system reference");
                lines.add("Reserved prosthetics should replace or augment damaged limbs through clinics, Mechanist Collegia service, rare parts, faction access, and cost.");
                break;
        }
        return lines;
    }

    java.util.List<String> heatInfopediaLines(String entry) {
        ArrayList<String> lines = new ArrayList<>();
        switch(entry) {
            case "Heat and Suspicion Overview":
                lines.add("Attention pressure overview");
                lines.add("Current pressure: gang heat " + gangHeat + ", Civic Wardens suspicion " + suspicion + ". Heat is criminal/local danger; suspicion is procedural/legal attention.");
                break;
            case "Hourly Decay":
                lines.add("Attention decay reference");
                lines.add("Once each 100-turn hour, heat and suspicion decay by 1 while awake. Sleeping counts as laying low and decays each by 2 per hour.");
                lines.add("If no base is claimed, suspicion receives one extra hourly decay point because the character is not leaving a stable property trail yet.");
                break;
            case "Heat Sources":
                lines.add("Gang heat source reference");
                lines.add("Heat rises from criminal violence, gang spaces, failed illegal work, noisy construction, obvious theft, hostile attention, and reckless underhive behavior.");
                break;
            case "Suspicion Sources":
                lines.add("Civic Wardens suspicion source reference");
                lines.add("Suspicion rises from law attention, illegal shrine/vending/security interactions, visible contraband work, official failures, and poor disguise outcomes.");
                break;
            default:
                lines.add("Attention avoidance reference");
                lines.add("Laying low, sleeping, lawful permits, better disguise behavior, and avoiding noisy crimes reduce pressure or prevent new pressure.");
                lines.add("Security and barricades improve raid defense but may also make a base more visible as an organized operation.");
                break;
        }
        return lines;
    }

    java.util.List<String> xpInfopediaLines(String entry) {
        ArrayList<String> lines = new ArrayList<>();
        switch(entry) {
            case "XP Overview":
                lines.add("Experience and knowledge-credit overview");
                lines.add("Current XP: " + xp + ". Knowledge credits: " + knowledgeCredits + ". One knowledge credit is awarded for each 25 XP band crossed.");
                lines.add("XP measures practice; knowledge credits buy or unlock doctrine entries where the design needs explicit permissions.");
                break;
            case "Task XP":
                lines.add("General task XP reference");
                lines.add("Actions award small visible amounts through RECENT ACTIONS. Failed attempts still teach something; success teaches more.");
                break;
            case "Combat XP":
                lines.add("Combat XP reference");
                lines.add("Misses award 1 XP; hits award about 3 XP; incapacitating a hostile rewards more once the strike lands.");
                break;
            case "Scavenge XP":
                lines.add("Scavenge XP reference");
                lines.add("Failed scrounging grants 1 XP; finding useful loot grants 2 XP. Targeted searches use the same feedback path.");
                break;
            case "Trade XP":
                lines.add("Commerce XP reference");
                lines.add("Buying, selling, and especially successful haggle attempts award Commerce XP. Trade XP supports the business/faction economy path.");
                break;
            default:
                lines.add("Construction XP reference");
                lines.add("Successful base construction awards Mechanics XP. Later fabrication, maintenance, and machine repair should use this same path.");
                break;
        }
        return lines;
    }

    java.util.List<String> knowledgeReferenceLines(String entry) {
        ArrayList<String> lines = new ArrayList<>();
        switch(entry) {
            case "Knowledge Overview":
                lines.add("Knowledge system overview");
                lines.add("Knowledge is the permission layer for recipes, machines, services, business paths, faction work, and conversation options.");
                lines.add("Current XP: " + xp + ". Spendable knowledge credits: " + knowledgeCredits + ". Credits come from XP bands and some research/contract paths.");
                lines.add("Design split: stats are aptitude, XP is practice, and knowledge is explicit doctrine or access.");
                break;
            case "Known Knowledge":
                lines.add("Known doctrine ledger");
                lines.add("Scope: lists what this save already knows; it is not the purchase rules and not the system overview.");
                lines.addAll(knownKnowledgeLines());
                lines.add("Known entries should gate visible recipes, machine actions, services, conversations, and actor permissions.");
                break;
            case "Purchasing Knowledge":
                lines.add("Knowledge purchase reference");
                lines.add("Scope: explains spending knowledge credits from this tab. It deliberately does not list every known doctrine.");
                lines.add("Spendable knowledge credits: " + knowledgeCredits + ". Knowledge purchases now belong to the Character Dossier Knowledge Tree, not this reference tab.");
                lines.add("Later purchases may also require faction standing, tutors, books, data slates, rare items, or legal access.");
                break;
            case "Training Sources":
                lines.add("Training and discovery source reference");
                lines.add("Knowledge may come from XP bands, trainers, traders, data slates, shrines, libraries, Micro Labs, faction services, contracts, and item study.");
                lines.add("Current discovered doctrine count: " + unlockedKnowledges.size() + ".");
                break;
            default:
                lines.add("Knowledge system reference");
                lines.add("Current integrations already gate EMM builds, production recipes, recruit berthing, labor discipline, commerce, and quality/faction production paths.");
                lines.add("Next integrations should move actor permissions, business management, recruit-operated machines, contracts, and faction production through the same knowledge authority.");
                break;
        }
        return lines;
    }

