    void configureBaseObject(BaseObject obj) {
        if (obj.qualityName == null || obj.qualityName.isBlank()) obj.qualityName = ItemQuality.NAMES[Math.max(0, Math.min(ItemQuality.NAMES.length-1, ItemQuality.tierIndex(obj.name + " machine")))];
        if (obj.faction == null) obj.faction = Faction.NONE;
        switch (obj.symbol) {
            case 's': obj.capacity = 30; obj.integrity = 12; obj.description = "A lockable crate. Extends base storage and makes hoarding slightly less insane."; break;
            case 'w': obj.capacity = 8; obj.integrity = 10; obj.charges = 0; obj.description = "A scrap workbench. Converts junk into supplies, assembles crude parts, and repairs clothing at a cost."; break;
            case 'd': obj.integrity = 18; obj.cover = 2; obj.description = "A barricade. Slows raids and grants cover, while loudly advertising that something inside is worth taking."; break;
            case 'c': obj.integrity = 8; obj.charges = 0; obj.description = "A sleeping cot. Reduces fatigue and allows slow wound/body-part recovery when the room is safe enough."; break;
            case 'u': obj.integrity = 10; obj.capacity = 12; obj.charges = 2; obj.description = "A sealed water barrel. Stores drinkable water and slowly condenses/traps usable moisture when left alone."; break;
            case 'a': obj.integrity = 6; obj.armed = false; obj.description = "A crude alarm trap. Can be armed to warn you of trouble, but it is noisy and not exactly elegant."; break;
            case 'p': obj.integrity = 11; obj.cover = 1; obj.armed = true; obj.description = "A raised watch post. Recruits assigned to guard duty use it to spot trouble before it becomes inventory loss."; break;
            case 'g': obj.integrity = 16; obj.capacity = 4; obj.cover = 1; obj.description = "A guard barracks. Houses security shifts, improves raid response, and makes the base look deliberately defended."; break;
            case 'D': obj.integrity = 22; obj.cover = 3; obj.description = "A reinforced internal door. It slows raids, protects storage, and creates useful choke points."; break;
            case 'S': obj.integrity = 28; obj.cover = 4; obj.description = "A sandbag line. Passive ballistic cover and physical roadblock semantics; no invisible defense math."; break;
            case 'R': obj.integrity = 18; obj.cover = 1; obj.armed = true; obj.description = "A razor wire coil. Inspectable area-denial hardware; movement injury hooks wait for hazard authority."; break;
            case 'W': obj.integrity = 70; obj.cover = 5; obj.description = "A reinforced defensive wall panel. Physical hard cover and perimeter structure for gate/sector defense."; break;
            case 'N': obj.integrity = 24; obj.capacity = 3; obj.charges = 1; obj.description = "A security sensor mast. Visible detection hardware for alarm, LOS, and ownership-safe routing."; break;
            case 'Y': obj.integrity = 65; obj.cover = 3; obj.description = "An Civic Wardens reinforced door. Precinct-grade choke point with access-control binding."; break;
            case 'J': obj.integrity = 78; obj.cover = 3; obj.armed = false; obj.capacity = 6; obj.description = "An Civic Wardens suppression turret profile. Built and inspectable with passive security coverage."; break;
            case 'U': obj.integrity = 70; obj.cover = 3; obj.armed = false; obj.capacity = 6; obj.description = "A heavy stub turret profile. Physical weapon mount only until ammo, power, staffing, and hostility rules exist."; break;
            case 'Z': obj.integrity = 62; obj.cover = 2; obj.armed = false; obj.capacity = 5; obj.description = "A gilded noble sentry turret profile. Expensive visible deterrent; autonomous targeting intentionally dormant."; break;
            case 'P': obj.integrity = 30; obj.cover = 1; obj.capacity = 2; obj.description = "A precinct defensive fixture set. Civic Wardens room props, checkpoint furnishings, and service/security anchors."; break;
            case 'e': obj.integrity = 9; obj.capacity = 16; obj.charges = 1; obj.description = "An emergency atmospheric condenser. Slowly turns poisoned damp into drinkable reserve."; break;
            case 'f': obj.integrity = 12; obj.capacity = 10; obj.description = "A micro forge. Converts scrap and parts into sturdier construction supplies."; break;
            case 'l': obj.integrity = 8; obj.description = "A micro lab. Early research foundation for base doctrine and ugly learning."; break;
            case 'x': obj.integrity = 10; obj.armed = true; obj.description = "A security logic Engine node. Improves base management and makes raids feel personally insulted."; break;
            case 'L': obj.integrity = 10; obj.capacity = 6; obj.charges = 0; obj.description = "Specialized laboratory or chemical apparatus. It satisfies non-consumed equipment requirements for generated chem/medicae recipes when placed in a valid room."; break;
            case 'B': obj.integrity = 9; obj.capacity = 18; obj.description = "A shop counter. Permitted counters produce lawful income; unpermitted counters sell anyway and raise heat."; break;
            case 'M': obj.integrity = 8; obj.capacity = 10; obj.description = "A medicae stall. Consumes medical goods for service income and can support recovery-oriented business later."; break;
            case 'T': obj.integrity = 18; obj.cover = 4; obj.armed = true; obj.charges = 3; obj.description = "A powered defense turret. Consumes power attention, but heavily improves raid defense when supplied."; break;
            case 'H': obj.integrity = 16; obj.cover = 5; obj.armed = true; obj.charges = 2; obj.description = "A shield relay. Projects hardened choke protection over valuable base assets and softens raid damage."; break;
            case 'v': obj.integrity = 6; obj.capacity = 1; obj.description = "A decor object. Improves shop presentation, recruit morale, and customer willingness to pay."; break;
            case 'A': obj.integrity = 8; obj.capacity = 2; obj.description = "A business add-on fixture. Shelving, signage, lockbox, display space, or service counter upgrades selling power."; break;
            case 'k': obj.integrity = 8; obj.capacity = 8; obj.description = "A carrying station. First-tier cargo staging for manual movement between nearby owned bases."; break;
            case 'q': obj.integrity = 12; obj.capacity = 20; obj.description = "A supply post. Second-tier cargo hub with organized bins, route slips, and faction labor staging."; break;
            case 'G': obj.integrity = 18; obj.capacity = 50; obj.description = "A logistics center. High-tier cargo authority for inter-base transfer, trade stock routing, and caravan dispatch."; break;
            default: obj.integrity = 5; obj.description = "A built object awaiting more specific rites.";
        }
        PassiveDefenseEffectsAuthority.annotate(obj);
        MachineTierAuthority.applyToConfiguredObject(obj);
    }

    void passiveBaseObjectTicks() {
        hourlyNpcFactionProductionTick();
        if (!baseClaimed || baseObjects.isEmpty()) return;
        for (BaseObject obj : baseObjects) {
            if ((obj.symbol == 'u' || obj.symbol == 'e') && turn % (obj.symbol == 'e' ? 6 : 8) == 0 && obj.charges < obj.capacity) {
                obj.charges++;
                water = Math.min(MAX_FOOD_WATER, water + 1);
                DebugLog.audit("BASE_WATER_PASSIVE", obj.name + " gathered 1 water. water=" + water + " objectCharges=" + obj.charges + " state=" + stateSummary());
                logEvent("The water barrel knocks softly as condensation collects. Water reserve +1.");
            }
            if (obj.symbol == 'a' && obj.armed && turn % 10 == 0) {
                DebugLog.audit("BASE_ALARM_LISTEN", "Alarm trap remains armed at " + obj.x + "," + obj.y + " heat=" + gangHeat + " suspicion=" + suspicion);
            }
            if ((obj.symbol == 'T' || obj.symbol == 'H') && obj.armed && turn % TURNS_PER_HOUR == 0 && obj.charges < obj.capacity) {
                obj.charges++;
                DebugLog.audit("BASE_POWER_DEFENSE_CHARGE", obj.name + " charge=" + obj.charges + "/" + obj.capacity + " state=" + stateSummary());
            }
        }
    }

    boolean hasBaseObject(char symbol) {
        for (BaseObject obj : baseObjects) if (obj.symbol == symbol) return true;
        return false;
    }

    BaseObject firstBaseObject(char symbol) {
        for (BaseObject obj : baseObjects) if (obj.symbol == symbol) return obj;
        return null;
    }

    void useComfortStructures() {
        if (!baseClaimed || !isInClaimedRoom(playerX, playerY)) { logEvent("Comfort structures require standing inside your claimed room."); return; }
        boolean did = false;
        BaseObject barrel = firstBaseObject('u');
        if (barrel != null && water > 0) {
            water--; barrel.charges = Math.max(0, barrel.charges - 1);
            fatigue = Math.max(0, fatigue - 2);
            did = true;
            logEvent("You drink from the water barrel. Fatigue -2. Water reserve " + water + ".");
            DebugLog.audit("BASE_USE_WATER", "water=" + water + " fatigue=" + fatigue + " state=" + stateSummary());
        }
        BaseObject cot = firstBaseObject('c');
        if (cot != null) {
            int oldFatigue = fatigue;
            fatigue = Math.max(0, fatigue - 4);
            if (wounds > 0 && water > 0) { wounds--; water--; logEvent("You rest on the cot and clean a wound. Wounds -1, water -1."); }
            else logEvent("You rest on the cot. Fatigue " + oldFatigue + " -> " + fatigue + ".");
            did = true;
            DebugLog.audit("BASE_USE_COT", "fatigue=" + fatigue + " wounds=" + wounds + " water=" + water + " state=" + stateSummary());
            advanceTurn("rests in a claimed room.");
        }
        if (!did) logEvent("No usable cot or filled water barrel is available yet.");
    }

    void workProcessScrap() {
        if (!canUseWorkbench()) return;
        int scrapIndex = inventory.lastIndexOf("Scrap bit");
        if (scrapIndex < 0) { logEvent("Workbench: no Scrap bit available to process."); return; }
        removeInventoryAtWithTrace(scrapIndex);
        supplies += 2;
        machineParts += 1;
        fatigue = Math.min(20, fatigue + 1);
        BaseObject bench = firstBaseObject('w'); if (bench != null) bench.charges++;
        logEvent("Workbench processed scrap: +2 supplies, +1 machine part, fatigue +1.");
        ProductionQueueRecordBridge.recordWorkbenchAction(this, firstBaseObject('w'), "process scrap", 1, active == null ? "player manual operation" : active.name + " manual operation");
        DebugLog.audit("WORKBENCH_PROCESS_SCRAP", "supplies=" + supplies + " parts=" + machineParts + " fatigue=" + fatigue + " state=" + stateSummary());
        advanceTurn("processes scrap at the workbench.");
    }

    void workRepairClothing() {
        if (!canUseWorkbench()) return;
        if (equippedClothing == null || !equippedClothing.damaged) { logEvent("Workbench: equipped clothing is not damaged."); return; }
        if (supplies < 2 || machineParts < 1) { logEvent("Workbench: repairing clothing needs 2 supplies and 1 machine part."); return; }
        supplies -= 2; machineParts -= 1; equippedClothing.damaged = false;
        logEvent("Workbench repaired your damaged clothing. It may once again pass as deliberate misery.");
        ProductionQueueRecordBridge.recordWorkbenchAction(this, firstBaseObject('w'), "repair clothing", 1, active == null ? "player manual operation" : active.name + " manual operation");
        DebugLog.audit("WORKBENCH_REPAIR_CLOTHING", "supplies=" + supplies + " parts=" + machineParts + " clothing=" + equippedClothing.name + " state=" + stateSummary());
        advanceTurn("repairs clothing at the workbench.");
    }

    void workAssembleParts() {
        if (!canUseWorkbench()) return;
        int detritus = inventory.lastIndexOf("Mechanical detritus");
        if (detritus < 0 || supplies < 1) { logEvent("Workbench: assembling parts needs Mechanical detritus and 1 supply."); return; }
        removeInventoryAtWithTrace(detritus); supplies -= 1; machineParts += 2; fatigue = Math.min(20, fatigue + 1);
        logEvent("Workbench assembled machine parts from detritus: +2 machine parts, -1 supply.");
        ProductionQueueRecordBridge.recordWorkbenchAction(this, firstBaseObject('w'), "assemble machine parts", 1, active == null ? "player manual operation" : active.name + " manual operation");
        DebugLog.audit("WORKBENCH_ASSEMBLE_PARTS", "supplies=" + supplies + " parts=" + machineParts + " fatigue=" + fatigue + " state=" + stateSummary());
        advanceTurn("assembles machine parts at the workbench.");
    }

