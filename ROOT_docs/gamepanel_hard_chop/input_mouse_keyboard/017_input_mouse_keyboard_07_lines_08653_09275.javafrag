    int countProductionInput(String item) {
        return ProductionContainerAuthority.countAvailable(this, item);
    }

    ProductionInputConsumptionRecord consumeProductionInputNamedResult(String item, String route) {
        return ProductionContainerAuthority.consumeOne(this, item, route);
    }

    boolean consumeProductionInputNamed(String item) {
        return consumeProductionInputNamedResult(item, "legacy production consume").success;
    }

