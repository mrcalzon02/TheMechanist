    String currentZoneKey() {
        if (atlas == null) return "0,0,0,0,0,false";
        return atlas.sectorX + "," + atlas.sectorY + "," + atlas.zoneX + "," + atlas.zoneY + "," + atlas.floor + "," + atlas.sewer;
    }

// ... omitted 33 non-method/source lines between cataloged methods ...

    String keySafe(String s) { return s == null ? "" : s; }

