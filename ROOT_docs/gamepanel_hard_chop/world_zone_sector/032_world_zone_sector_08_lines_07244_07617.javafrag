    boolean isIntermapTransitTile(char ch) { return ch == 'D' || ch == 'S' || ch == 'v' || ch == 'E'; }

    String intermapTransitLabel(char ch) {
        switch (ch) {
            case 'D': return "Maintenance-bulkhead double doors";
            case 'S': return "Sewer access hatch";
            case 'v': return "Sewer ladder / drain ascent";
            case 'E': return "Elevator cage";
            default: return "Intermap transit";
        }
    }


    boolean hasOffworldTicket() {
        for (String item : inventory) if (item != null && item.equalsIgnoreCase("Off-world ticket")) return true;
        return false;
    }

    void useOffworldTicketAtRail() {
        if (!selectedInteractionIsSectorRail()) { logEvent("Off-world departure failed: select a rail authority counter or platform marker in a Neutral Rail Depot."); return; }
        if (!hasOffworldTicket()) { logEvent("Off-world departure blocked: no genuine Off-world ticket is carried. Find a governor who has one, bribe them, or take it from their body."); return; }
        offworldTicketsFound = Math.max(offworldTicketsFound, 1);
        alertTitle = "OFF-WORLD PASSAGE SECURED";
        alertBody = "The rail authority validates the impossible ticket. The sector, your warrants, your abandoned enemies, and every hungry room behind you become someone else's accounting problem. Victory route complete.";
        logEvent("VICTORY: Off-world ticket accepted at the rail authority. You escape the sector stack.");
        DebugLog.audit("OFFWORLD_VICTORY", "ticket=true state=" + stateSummary());
        setScreen(Screen.ZONE_SPLASH);
    }

    void takeSectorRailToNewSector() {
        if (!selectedInteractionIsSectorRail()) { logEvent("Sector rail failed: select a rail platform or depot counter inside a Neutral Rail Depot."); return; }
        int fare = sectorRailFare();
        if (!spendImperialScript(fare)) {
            logEvent("Sector rail blocked: passage to another sector costs " + fare + " Concord Script. You have " + countMoney() + ".");
            return;
        }
        int abandonedObjects = baseObjects.size();
        int abandonedRecruits = factionRecruits.size();
        int abandonedStorage = baseStorage.size();
        long oldSeed = seed;
        seed = mixNewSectorSeed(seed, turn, countMoney(), xp, knowledgeCredits);
        atlas = new WorldAtlas(seed);
        atlas.generateScaffold();
        atlas.sectorX = 1; atlas.sectorY = 1; atlas.zoneX = 2; atlas.zoneY = 2; atlas.floor = 5; atlas.sewer = false;
        baseClaimed = false; baseX = -1; baseY = -1; claimedRoomId = -1;
        baseObjects.clear(); baseStorage.clear(); factionRecruits.clear();
        gangHeat = Math.max(0, gangHeat / 4);
        suspicion = Math.max(0, suspicion / 4);
        factionMarketPressure.clear(); initFactionState();
        visitedZoneInstances.clear(); visitedZoneTypes.clear();
        scavengeCooldownUntilTurn.clear();
        loadingForNewGame = false;
        loadingForTransition = true;
        loadingProgress = 0; loadingStep = 0; loadingStartMillis = System.currentTimeMillis();
        lastLoadingPulseMillis = loadingStartMillis; loadingWatchdogReported = false; loadingWatchdogRepeats = 0;
        loadingStatus = "Taking sector rail to a new jurisdiction.";
        loadingDetail = "Abandoning local bases/recruits/storage; preserving carried inventory, body state, XP, and unlocked knowledge.";
        pendingTransitionReason = "sector rail relocation";
        pendingTransitionEdgeHint = null;
        pendingTransitionReturnEdge = "";
        logEvent("SECTOR RAIL: fare " + fare + " paid. Abandoned " + abandonedObjects + " base objects, " + abandonedRecruits + " recruits, and " + abandonedStorage + " stored goods. Carried items and knowledge remain.");
        DebugLog.audit("SECTOR_RAIL_DEPART", "oldSeed=" + oldSeed + " newSeed=" + seed + " fare=" + fare + " abandonedObjects=" + abandonedObjects + " abandonedRecruits=" + abandonedRecruits + " abandonedStorage=" + abandonedStorage + " state=" + stateSummary());
        setScreen(Screen.LOADING);
    }

    int sectorRailFare() {
        int carried = Math.max(0, inventory.size());
        int notoriety = Math.max(0, gangHeat + suspicion) / 10;
        return Math.max(12, 25 + carried / 4 + notoriety);
    }

    long mixNewSectorSeed(long oldSeed, int turnCount, int money, int xpValue, int knowledgeValue) {
        long x = oldSeed ^ 0x5EC70A7E47A11L;
        x ^= ((long)turnCount << 21) ^ ((long)money << 9) ^ ((long)xpValue << 3) ^ knowledgeValue;
        x ^= (x << 13); x ^= (x >>> 7); x ^= (x << 17);
        return x == 0 ? System.currentTimeMillis() : x;
    }

    void interactIntermapTransit(int tx, int ty, char ch) {
        String preview = transitionPreview(ch, tx, ty);
        DebugLog.audit("INTERMAP_TRANSIT_SELECT", intermapTransitLabel(ch)+" at="+tx+","+ty+" preview="+preview+" state="+stateSummary());
        logEvent("Transit selected: " + preview);
        switch (ch) {
            case 'D': interactZoneEdgeDoor(tx, ty); break;
            case 'S': interactSewerHatch(tx, ty); break;
            case 'v': interactSewerLadder(tx, ty); break;
            case 'E': interactElevator(tx, ty); break;
            default: logEvent("This transit marker has no mapped destination yet.");
        }
    }

    String transitionPreview(char ch, int tx, int ty) {
        if (atlas == null || world == null) return "No atlas loaded.";
        if (ch == 'D') {
            String dir = edgeDirection(tx, ty);
            int nzx = atlas.zoneX, nzy = atlas.zoneY, nsx = atlas.sectorX, nsy = atlas.sectorY;
            if ("N".equals(dir)) nzy--; else if ("S".equals(dir)) nzy++; else if ("W".equals(dir)) nzx--; else if ("E".equals(dir)) nzx++;
            if (nzx < 1 || nzx > 3 || nzy < 1 || nzy > 3) return "The double doors open toward interwall voids and crawlways. No sane human goes there.";
            return "Travel through double doors " + dir + " to sector " + nsx + "," + nsy + " zone " + nzx + "," + nzy + " floor " + atlas.floor + (atlas.sewer ? "B" : "") + ".";
        }
        if (ch == 'S') return "Open sewer hatch and descend to Floor " + atlas.floor + "B beneath this zone.";
        if (ch == 'v') return "Climb the sewer ladder back to Floor " + atlas.floor + " above this sewer layer.";
        if (ch == 'E') return "Operate elevator to Floor " + Math.min(10, atlas.floor + 1) + " in this zone, skipping the sewer interlayer.";
        return "Unknown transition.";
    }

