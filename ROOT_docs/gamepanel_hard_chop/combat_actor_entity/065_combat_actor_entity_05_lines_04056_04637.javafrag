    void beginCombatTargeting() {
        if (world == null || active == null) { logEvent("Combat failed: no active world or character is loaded."); return; }
        explosiveTargetingMode = false;
        selectedExplosiveItem = "";
        combatCursorActive = true;
        combatX = Math.max(0, Math.min(world.w-1, playerX + Math.max(-1, Math.min(1, lastMoveDx))));
        combatY = Math.max(0, Math.min(world.h-1, playerY + Math.max(-1, Math.min(1, lastMoveDy))));
        if (combatX == playerX && combatY == playerY) combatX = Math.min(world.w-1, playerX + 1);
        lookCursorActive = false;
        interactCursorActive = false;
        lastTargetingReport = "Targeting reticle armed. Move reticle; Enter/Space confirms; F cycles fire mode; G throws a carried explosive.";
        openPanel(PanelMode.COMBAT);
    }

    void moveCombatCursor(int dx, int dy) {
        if (world == null) return;
        combatCursorActive = true;
        if (combatX < 0 || combatY < 0) { combatX = playerX; combatY = playerY; }
        combatX = Math.max(0, Math.min(world.w-1, combatX + dx));
        combatY = Math.max(0, Math.min(world.h-1, combatY + dy));
        if (explosiveTargetingMode) lastTargetingReport = explosiveTargetingSummary(combatX, combatY);
        else {
            TargetingSolution ts = targetingSolutionAt(combatX, combatY);
            lastTargetingReport = ts.summaryLine();
        }
    }

    void confirmCombatTarget() {
        if (singlePlayerSectorBridge.shouldOwnAuthoritativeTurns(this) && !singlePlayerSectorBridge.insideAuthoritativeTurn()) {
            singlePlayerSectorBridge.submitCommand(this, new ConfirmCombatCommand(SinglePlayerSectorRuntimeBridge.LOCAL_PLAYER_ID, combatX, combatY));
            repaint();
            return;
        }
        confirmCombatTargetBody();
    }

    void confirmCombatTargetBody() {
        if (world == null || active == null) return;
        if (explosiveTargetingMode) { throwSelectedExplosiveAtCursor(); return; }
        TargetingSolution ts = targetingSolutionAt(combatX, combatY);
        lastTargetingReport = ts.summaryLine();
        if (!ts.canFire) { logEvent("TARGETING BLOCKED: " + ts.summaryLine()); return; }
        performCombatAttackAt(ts);
    }

