    void ensureNpcCombatLoadout(NpcEntity npc) {
        if (npc != null) npc.ensureCombatLoadout(rng == null ? new Random(npc.numericId) : rng);
    }

    int npcLoadedShotsForWeapon(NpcEntity npc) {
        ensureNpcCombatLoadout(npc);
        return npc == null ? 0 : Math.max(0, npc.loadedShots);
    }

    int npcReserveReloadsForWeapon(NpcEntity npc) {
        ensureNpcCombatLoadout(npc);
        return npc == null ? 0 : Math.max(0, npc.ammoReloadsRemaining);
    }

    int npcWeaponCapacity(NpcEntity npc) {
        ensureNpcCombatLoadout(npc);
        return npc == null ? 0 : magazineCapacityForWeapon(npc.equippedRangedWeapon);
    }

