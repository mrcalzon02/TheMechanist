    int soundChance(char ch, int x, int y, int dist) {
        int base = 15 + stat("Hearing", 6) * 6 - dist * 4 - noisePenaltyAt(x,y);
        if (ch == 'N' || ch == 'R') base += 18;
        if (ch == 'A' || ch == 'p' || ch == 'M') base += 8;
        return Math.max(3, Math.min(85, base));
    }
