    RecruitWorker selectedStaffingWorker() {
        if (factionRecruits.isEmpty()) return null;
        selectedStaffingWorkerIndex = Math.max(0, Math.min(selectedStaffingWorkerIndex, factionRecruits.size()-1));
        return factionRecruits.get(selectedStaffingWorkerIndex);
    }
