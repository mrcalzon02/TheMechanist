    void ensureRuntimeTimerRunning(String reason) {
        if (!timer.isRunning()) {
            timer.start();
            try { DebugLog.warn("RUNTIME_TIMER_RESTART", "Swing timer was stopped; restarted for " + reason + "."); } catch (Throwable ignored) {}
        }
    }
