    BaseObject selectedStaffingStation() {
        ArrayList<BaseObject> stations = staffableStations();
        if (stations.isEmpty()) return null;
        return stations.get(Math.max(0, Math.min(selectedStaffingStationIndex, stations.size()-1)));
    }
