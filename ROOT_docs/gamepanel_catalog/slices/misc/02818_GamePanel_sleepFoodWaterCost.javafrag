    int sleepFoodWaterCost(int hours) {
        boolean uninjured = wounds <= 0 && totalBodyDamagePercent() <= 0.1;
        double rate = uninjured ? 5.0 / 32.0 : 5.0 / 8.0;
        return Math.max(1, (int)Math.ceil(hours * rate));
    }
