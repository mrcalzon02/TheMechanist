    void requestApplicationExit(String reason) {
        DebugLog.audit("APPLICATION_EXIT", reason == null ? "unspecified" : reason);
        shutdownRuntime();
        Window w = SwingUtilities.getWindowAncestor(this);
        if (w != null) w.dispose();
        System.exit(0);
    }
