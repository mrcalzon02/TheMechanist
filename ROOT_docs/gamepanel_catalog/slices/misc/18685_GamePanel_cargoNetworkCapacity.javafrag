    int cargoNetworkCapacity() {
        int cap = 0;
        for (BaseObject obj : baseObjects) if (obj.symbol == 'k' || obj.symbol == 'q' || obj.symbol == 'G') cap += Math.max(0, obj.capacity);
        return cap;
    }
