    void tradeAskRumors() {
        if (world == null) return;
        lastTradeReport = "Rumor: this zone is " + world.zoneType.label + ". Room tables favor " + world.zoneType.descriptor + ". Sector map remains fogged until visited.";
        logEvent(lastTradeReport); advanceTurn("asks depot rumors.");
    }
