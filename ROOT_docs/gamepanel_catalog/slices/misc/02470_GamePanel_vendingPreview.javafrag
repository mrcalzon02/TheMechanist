    String vendingPreview(char ch, int x, int y) {
        String key = passiveKey(x,y);
        int until = passiveCooldownUntilTurn.getOrDefault(key, 0);
        int hacked = vendingHackVendCount.getOrDefault(key, 0);
        return PublicServiceMediaAuthority.vendingPreview(ch, until, hacked);
    }
