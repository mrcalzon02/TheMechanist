    void multiplayerJoinDirect() {
        NetworkPortAuthority.Endpoint endpoint = multiplayerMenu.joinDirect();
        logEvent("MULTIPLAYER DIRECT ENDPOINT: " + endpoint.display());
        showTimedAlert("DIRECT JOIN READY", endpoint.display(), 3600);
        repaint();
    }
