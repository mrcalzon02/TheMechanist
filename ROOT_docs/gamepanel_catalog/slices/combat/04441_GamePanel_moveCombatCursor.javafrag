    void moveCombatCursor(int dx, int dy) {
        if (world == null) return;
        combatCursorActive = true;
        if (combatX < 0 || combatY < 0) { combatX = playerX; combatY = playerY; }
        combatX = Math.max(0, Math.min(world.w-1, combatX + dx));
        combatY = Math.max(0, Math.min(world.h-1, combatY + dy));
        if (explosiveTargetingMode) lastTargetingReport = explosiveTargetingSummary(combatX, combatY);
        else {
            TargetingSolution ts = targetingSolutionAt(combatX, combatY);
            lastTargetingReport = ts.summaryLine();
        }
    }
