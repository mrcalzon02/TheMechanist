    boolean lightSourceCurrentlyEmitting(ZoneLightSourceRecord l) {
        if (l == null || !l.on || !l.powered) return false;
        if (l.flicker && Math.floorMod(turn + l.phase, Math.max(2, l.flickerPeriod)) == 0) return false;
        return true;
    }
