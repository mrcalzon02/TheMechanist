    void cycleLightingFx() {
        int next = (options.lightingFxIndex + 1) % GameOptions.LIGHTING_FX_LABELS.length;
        logEvent(OptionsBoundaryAuthority.setLightingFxIndex(options, next));
        repaint();
    }
