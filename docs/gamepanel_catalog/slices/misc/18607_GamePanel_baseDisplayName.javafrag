    String baseDisplayName() {
        if (!baseClaimed) return "No Claimed Base";
        if (world == null) return "Room " + claimedRoomId + " Holding";
        String z = world.zoneType == null ? "Underhive" : world.zoneType.label;
        return z + " Holding " + Math.max(0, claimedRoomId);
    }
