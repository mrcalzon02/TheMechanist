    int nearbyWitnessCount(int x, int y, int range) {
        if (world == null) return 0;
        int c = 0;
        for (NpcEntity n : world.npcs) if (n != null && Math.abs(n.x-x)+Math.abs(n.y-y) <= range && !isHostileNpc(n)) c++;
        return c;
    }
