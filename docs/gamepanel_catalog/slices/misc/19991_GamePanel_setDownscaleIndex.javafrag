    void setDownscaleIndex(int idx) {
        logEvent(OptionsBoundaryAuthority.setDownscaleIndex(options, idx));
        renderScaling.applyOptions(options);
        graphicsDropdown = -1;
        DebugLog.audit("RENDER_DOWNSCALE", renderScaling.auditSummary());
        repaint();
    }
