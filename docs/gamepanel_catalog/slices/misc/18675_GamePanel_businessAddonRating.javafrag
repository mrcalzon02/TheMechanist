    int businessAddonRating() {
        int n = 0;
        for (BaseObject obj : baseObjects) if (obj.symbol == 'A') n += Math.max(1, ItemQuality.tierIndex((obj.qualityName==null?"Common":obj.qualityName)+" addon")/2 + 1);
        return n;
    }
