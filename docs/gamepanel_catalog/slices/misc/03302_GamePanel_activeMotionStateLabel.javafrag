    String activeMotionStateLabel() {
        if (activeMotionStateIndex == MOTION_STATIONARY) return "STATIONARY";
        int idx = Math.max(0, Math.min(MOVEMENT_MODE_LABELS.length-1, activeMotionStateIndex));
        return MOVEMENT_MODE_LABELS[idx];
    }
