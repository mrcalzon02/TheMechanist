    int fireModeAmmoCost(String weapon) {
        if (!ItemCatalog.isFirearmLike(weapon)) return 0;
        String fm = fireModeLabel();
        if ("BURST".equals(fm)) return Math.min(3, Math.max(1, magazineCapacityForWeapon(weapon)));
        return 1;
    }
