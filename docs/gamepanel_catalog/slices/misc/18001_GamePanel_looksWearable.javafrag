    boolean looksWearable(String item) {
        String low = item.toLowerCase(Locale.ROOT);
        return low.contains("clothing") || low.contains("coat") || low.contains("rags") || low.contains("uniform") || low.contains("workwear") || low.contains("colors") || low.contains("robe");
    }
