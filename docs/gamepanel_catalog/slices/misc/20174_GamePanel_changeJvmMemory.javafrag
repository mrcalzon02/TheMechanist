    void changeJvmMemory(int deltaMb) {
        JvmRuntimeProfileAuthority.changeMemory(jvmRuntimeProfile, deltaMb);
        markJvmProfileChanged("JVM max heap profile now " + jvmRuntimeProfile.maxRamMb + " MB.");
    }
