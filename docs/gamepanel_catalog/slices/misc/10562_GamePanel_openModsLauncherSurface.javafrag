    void openModsLauncherSurface() {
        logEvent(launcherShell.activate(LauncherShellStateAuthority.Route.MODS, "main menu mods/tools"));
        String body = launcherRuntime.openModsSurface();
        logEvent(body);
        setScreen(Screen.MODS);
        repaint();
    }
