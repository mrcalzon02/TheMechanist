    void toggleGraphicsDropdown(int which) {
        graphicsDropdown = (graphicsDropdown == which) ? -1 : which;
        logEvent("Graphics dropdown " + (graphicsDropdown < 0 ? "closed" : "opened") + ".");
        repaint();
    }
