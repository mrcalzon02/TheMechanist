    void npcLeaveConversation() {
        if (activeConversationNpc != null) logConversation("NPC_LEAVE", "Ended conversation with " + activeConversationNpc.name + ".");
        activeConversationNpc = null;
        activeTrader = null;
        closePanel();
    }
