    void setLoadedShotsForWeapon(String weapon, int shots) {
        String key = weaponLoadKey(weapon);
        int cap = magazineCapacityForWeapon(weapon);
        if (cap <= 0 || shots <= 0) loadedWeaponShots.remove(key);
        else loadedWeaponShots.put(key, Math.min(cap, shots));
    }
