    void multiplayerSaveFavorite() {
        multiplayerMenu.addFavoriteFromDirect("Favorite " + (multiplayerMenu.favorites().size() + 1));
        logEvent("MULTIPLAYER FAVORITE SAVED: " + multiplayerMenu.directInput());
        repaint();
    }
