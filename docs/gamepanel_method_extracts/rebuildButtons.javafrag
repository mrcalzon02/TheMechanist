                buttons.add(new ButtonBox("SAVE DIAGNOSTIC", sl.manual.x + 14, sl.manual.y + 54, Math.max(80, sl.manual.width - 28), topButtonH,
                        "Record a compact save-health report for troubleshooting.", this::logPersistenceDiagnostic));
                buttons.add(new ButtonBox("LOAD MENU", sl.auto.x + 14, sl.auto.y + 54, Math.max(80, sl.auto.width - 28), topButtonH,
                        "Manual saves and autosaves are listed in separate columns.", () -> logEvent("The load menu is already open.")));
                int rowGap = Math.max(4, scaled(4));
                int rowStart = sl.manual.y + 90;
                int available = Math.max(72, sl.manual.y + sl.manual.height - 18 - rowStart);
                int rowH = Math.max(18, Math.min(28, (available - rowGap * Math.max(0, SAVE_SLOT_COUNT - 1)) / Math.max(1, SAVE_SLOT_COUNT)));
                int half = Math.max(60, (sl.manual.width - 36) / 2);
                for (int i=1;i<=SAVE_SLOT_COUNT;i++) {
                    final int slot=i;
                    int sy=rowStart+(i-1)*(rowH+rowGap);
                    buttons.add(new ButtonBox("MANUAL " + i + " LOAD", sl.manual.x + 14, sy, half, rowH, "Load manual save slot " + i + ".", () -> loadGameSlot(slot)));
                    buttons.add(new ButtonBox("SAVE " + i, sl.manual.x + 22 + half, sy, Math.max(60, sl.manual.width - 36 - half), rowH, "Write the active run into manual save slot " + i + ".", () -> saveGameSlot(slot)));
                }
                int[] autos = { AUTOSAVE_HOURLY_SLOT, AUTOSAVE_ZONE_SLOT, -1001, -1002, -1003 };
                String[] labels = { "AUTO 1 HOUR", "AUTO 2 ZONE", "AUTO 3 EMPTY", "AUTO 4 EMPTY", "AUTO 5 EMPTY" };
                int autoRows = labels.length;
                int autoAvailable = Math.max(90, sl.auto.y + sl.auto.height - 18 - rowStart);
                int autoRowH = Math.max(18, Math.min(28, (autoAvailable - rowGap * Math.max(0, autoRows - 1)) / Math.max(1, autoRows)));
                for (int i=0;i<labels.length;i++) {
                    final int slot = autos[i];
                    final int ordinal = i + 1;
                    int sy=rowStart+i*(autoRowH+rowGap);
                    if (slot == -1001 || slot == -1002 || slot == -1003) {
                        buttons.add(new ButtonBox(labels[i], sl.auto.x + 14, sy, Math.max(80, sl.auto.width - 28), autoRowH, "Empty autosave column slot.", () -> logEvent("Autosave slot " + ordinal + " is empty.")));
                    } else {
                        buttons.add(new ButtonBox(labels[i], sl.auto.x + 14, sy, Math.max(80, sl.auto.width - 28), autoRowH, "Load autosave slot " + ordinal + ".", () -> loadGameSlot(slot)));
                    }
                }
