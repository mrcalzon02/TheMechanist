                buttons.add(new ButtonBox("DISGUISE", slotX, slotButtonY, 217, 28, "Open clothing, cover identity, and masquerade odds from the equipment slot panel.", () -> openPanel(PanelMode.DISGUISE)));
                if (equippedItemForSlot(selectedEquipmentSlotIndex) != null && !equippedItemForSlot(selectedEquipmentSlotIndex).isBlank()) {
                    buttons.add(new ButtonBox("INSPECT SLOT", slotX, slotButtonY + 34, 217, 28, "Inspect the selected equipped item.", () -> logEvent("EQUIPMENT SLOT: " + equipmentSlotNames()[selectedEquipmentSlotIndex] + " contains " + equippedItemForSlot(selectedEquipmentSlotIndex) + ".")));
                    buttons.add(new ButtonBox("UNEQUIP", slotX, slotButtonY + 68, 217, 28, "Move the selected equipped item back to carried inventory if possible.", this::unequipSelectedEquipmentSlot));
                }
            } else if (panelMode == PanelMode.SAVELOAD) {
