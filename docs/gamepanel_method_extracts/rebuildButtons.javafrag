                int panelW = Math.min(880, w - panelX*2);
                int panelH = Math.min(440, h - panelY - 54);
                int gap = Math.max(10, scaled(10));
                int actionW = Math.max(150, Math.min(220, panelW/4));
                int actionX = panelX + panelW - actionW - 22;
                int actionY = panelY + 106;
                int bw = actionW;
                int bh = Math.max(28, Math.min(34, (panelH - 176) / 7));
                int step = bh + Math.max(6, scaled(6));
                String invSel = selectedInventoryStackName();
                String targetSel = selectedTargetInventoryName();
                int n = 0;
                if (!inventoryTargetColumnActive && invSel != null) {
                    buttons.add(new ButtonBox("USE / EQUIP", actionX, actionY + step*(n++), bw, bh, "Use the selected carried item or equip it if it belongs on the paper doll.", this::useSelectedInventoryItem));
                    buttons.add(new ButtonBox("DROP ONE", actionX, actionY + step*(n++), bw, bh, "Drop one unit of the selected stack.", this::dropSelectedInventoryItem));
                    buttons.add(new ButtonBox("INSPECT", actionX, actionY + step*(n++), bw, bh, "Inspect the selected carried item in the bottom information pane.", this::inspectSelectedInventoryItem));
                    if (PortableLightProfile.isLightItem(invSel)) buttons.add(new ButtonBox("THROW LIGHT", actionX, actionY + step*(n++), bw, bh, "Throw the selected portable light in your facing direction if it can illuminate a landing tile.", this::throwSelectedPortableLight));
                } else if (inventoryTargetColumnActive && targetSel != null) {
                    buttons.add(new ButtonBox("TAKE TARGET", actionX, actionY + step*(n++), bw, bh, "Take the selected target/floor item when the target inventory supports transfer.", this::takeSelectedTargetInventoryItem));
                    buttons.add(new ButtonBox("TAKE ALL", actionX, actionY + step*(n++), bw, bh, "Take all transferable items from the selected target/container.", this::takeAllTargetInventoryItems));
                    buttons.add(new ButtonBox("INSPECT", actionX, actionY + step*(n++), bw, bh, "Inspect the selected target item or floor feature.", this::inspectSelectedInventoryItem));
                } else {
                    buttons.add(new ButtonBox("INSPECT", actionX, actionY, bw, bh, "Inspect the current inventory or floor tile state.", this::inspectSelectedInventoryItem));
                }
            } else if (panelMode == PanelMode.CHARACTER) {
                int cx = w/2 - 210;
                int cy = h - 118;
                buttons.add(new ButtonBox("FACTIONS", cx, cy, 190, 34, "Open faction standing and local political hostility from the character dossier.", () -> openPanel(PanelMode.FACTIONS)));
                int dossierFrameX = Math.max(24, w/45);
                int dossierFrameY = Math.max(44, h/18);
                int dossierFrameH = h - dossierFrameY - 46;
                int knowledgeButtonX = dossierFrameX + 28;
                int knowledgeButtonY = Math.max(dossierFrameY + 96, dossierFrameY + dossierFrameH - 64);
                buttons.add(new ButtonBox("KNOWLEDGE", knowledgeButtonX, knowledgeButtonY, 190, 34, "Open the character-owned knowledge and progression tree.", this::openKnowledgeMenu));
                int slotX = Math.max(40, w - 386);
