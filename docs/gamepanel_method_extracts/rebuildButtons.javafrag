                buttons.add(new ButtonBox("SCREENSAVER " + onOff(options.screenSaver), x+gap, y+rowStep, bw, bhOpt, "Toggle idle underhive skyline screensaver after fifteen minutes with no input.", () -> { options.screenSaver=!options.screenSaver; options.save(); logEvent("Screensaver " + (options.screenSaver?"enabled":"disabled") + "."); repaint(); }));
                addGraphicsDropdownButtons(x, y, bw, gap);
            } else if (optionsTab == 1) {
                buttons.add(new ButtonBox("TEXT " + options.fontScale + "% -", x, y, bw, bhOpt, "Reduce standard UI and custom-panel text scale. Compact text is the default; larger text is opt-in.", () -> changeFontScale(-1)));
                buttons.add(new ButtonBox("TEXT " + options.fontScale + "% +", x+gap, y, bw, bhOpt, "Increase standard UI and custom-panel text scale for accessibility or couch-distance play.", () -> changeFontScale(1)));
                buttons.add(new ButtonBox("TEXT CRISP: " + options.renderQualityLabel() + " ▼", x+gap*2, y, bw, bhOpt, "Select text crispness/rendering hints separately from text size.", () -> toggleGraphicsDropdown(5)));
                buttons.add(new ButtonBox("GUI SCALE -", x, y+rowStep, bw, bhOpt, "Reduce panel/button/chrome scale without changing text scale.", () -> changeUiScale(-1)));
                buttons.add(new ButtonBox("GUI SCALE +", x+gap, y+rowStep, bw, bhOpt, "Increase panel/button/chrome scale without changing text scale.", () -> changeUiScale(1)));
                buttons.add(new ButtonBox("HOVER HELP " + onOff(options.hoverHelp), x+gap*2, y+rowStep, bw, bhOpt, "Toggle floating mouse-over help labels beside the cursor.", () -> { options.hoverHelp=!options.hoverHelp; options.save(); logEvent("Floating hover help " + (options.hoverHelp?"enabled":"disabled") + "."); repaint(); }));
                addGraphicsDropdownButtons(x, y, bw, gap);
            } else if (optionsTab == 2) {
                buttons.add(new ButtonBox("SFX " + onOff(options.soundEnabled), x, y, bw, bhOpt, "Toggle all interface and effect sounds.", () -> { options.soundEnabled=!options.soundEnabled; options.save(); sounds.play("button", options); logEvent("Sound effects " + (options.soundEnabled?"enabled":"disabled") + "."); repaint(); }));
                buttons.add(new ButtonBox("SFX -", x+gap, y, bw, bhOpt, "Lower interface/effect sound volume.", () -> changeSfxVolume(-5)));
                buttons.add(new ButtonBox("SFX +", x+gap*2, y, bw, bhOpt, "Raise interface/effect sound volume.", () -> changeSfxVolume(5)));
                buttons.add(new ButtonBox("MUSIC " + onOff(options.musicEnabled), x, y+rowStep, bw, bhOpt, "Toggle music channel. No bundled music tracks are active in this build.", () -> { options.musicEnabled=!options.musicEnabled; options.save(); logEvent("Music channel " + (options.musicEnabled?"enabled":"disabled") + "."); repaint(); }));
                buttons.add(new ButtonBox("MUSIC -", x+gap, y+rowStep, bw, bhOpt, "Lower music channel volume.", () -> changeMusicVolume(-5)));
                buttons.add(new ButtonBox("MUSIC +", x+gap*2, y+rowStep, bw, bhOpt, "Raise music channel volume.", () -> changeMusicVolume(5)));
                buttons.add(new ButtonBox("VOICE " + onOff(options.conversationSound), x, y+rowStep*2, bw, bhOpt, "Toggle conversation/voice blip channel inherited from earlier assets.", () -> { options.conversationSound=!options.conversationSound; options.save(); sounds.play("type", options); logEvent("Conversation sounds " + (options.conversationSound?"enabled":"disabled") + "."); repaint(); }));
                buttons.add(new ButtonBox("VOICE -", x+gap, y+rowStep*2, bw, bhOpt, "Lower conversation sound volume.", () -> changeConversationVolume(-5)));
                buttons.add(new ButtonBox("VOICE +", x+gap*2, y+rowStep*2, bw, bhOpt, "Raise conversation sound volume.", () -> changeConversationVolume(5)));
                buttons.add(new ButtonBox("BOOT " + onOff(options.bootSound), x, y+rowStep*3, bw, bhOpt, "Toggle boot/typewriter sound layer.", () -> { options.bootSound=!options.bootSound; options.save(); logEvent("Boot sound " + (options.bootSound?"enabled":"disabled") + "."); repaint(); }));
            } else if (optionsTab == 3) {
                buttons.add(new ButtonBox("KEYBOARD", x, y, bw, bhOpt, "Show keyboard bindings.", () -> { controlsTab=0; repaint(); }));
                buttons.add(new ButtonBox("XBOX", x+gap, y, bw, bhOpt, "Show Xbox controller layout.", () -> { controlsTab=1; repaint(); }));
                buttons.add(new ButtonBox("PLAYSTATION", x+gap*2, y, bw, bhOpt, "Show PlayStation controller layout.", () -> { controlsTab=2; repaint(); }));
                buttons.add(new ButtonBox("STEAM", x, y+rowStep, bw, bhOpt, "Show Steam Deck/controller layout.", () -> { controlsTab=3; repaint(); }));
                buttons.add(new ButtonBox("GENERIC", x+gap, y+rowStep, bw, bhOpt, "Show generic SDL/Jamepad fallback layout.", () -> { controlsTab=4; repaint(); }));
                buttons.add(new ButtonBox("RECOVERY", x+gap*2, y+rowStep, bw, bhOpt, "Show required controls, contextual overlaps, and safe fallback notes.", () -> { rebindingTarget="Recovery reference: keep movement, confirm, cancel/back, pause, and menu access available."; logEvent("Controls recovery reference opened."); repaint(); }));
            } else if (optionsTab == 4) {
                buttons.add(new ButtonBox("DOWNSCALE: " + options.downscaleLabel() + " ▼", x, y, bw, bhOpt, "Choose the internal render-buffer scale. Lower values reduce Java2D render cost.", () -> toggleGraphicsDropdown(3)));
                buttons.add(new ButtonBox("TARGET FPS: " + options.targetFpsLabel() + " ▼", x+gap, y, bw, bhOpt, "Set best-effort Swing frame pacing. Server simulation is not tied to FPS.", () -> toggleGraphicsDropdown(4)));
                buttons.add(new ButtonBox("FRAME LIMIT " + options.frameLimitLabel(), x+gap, y+rowStep*5, bw, bhOpt, "Toggle strict target-FPS pacing versus uncapped rendering.", this::toggleFrameLimiter));
                buttons.add(new ButtonBox("ART QUALITY: " + options.artQualityLabel(), x, y+rowStep, bw, bhOpt, "Cycle deterministic source-art cache: Low 32, Standard 64, Intermediate 128, or High Native. Reloads tile and portrait cells.", this::cycleArtQuality));
                buttons.add(new ButtonBox("TILE SIZE: " + options.mapTileSizeLabel(), x+gap, y+rowStep, bw, bhOpt, "Cycle on-screen tile footprint. Compact helps old hardware and small screens; high is for close inspection.", this::cycleMapTileSize));
                buttons.add(new ButtonBox("TILE ART " + onOff(options.tileIconRendering), x+gap*2, y+rowStep, bw, bhOpt, "Toggle tile-icon map rendering. ASCII fallback remains preserved.", () -> { options.tileIconRendering=!options.tileIconRendering; options.save(); logEvent("Tile icon rendering " + (options.tileIconRendering?"enabled":"disabled") + "."); repaint(); }));
                buttons.add(new ButtonBox("PORTRAITS " + onOff(options.importedPortraits), x, y+rowStep*2, bw, bhOpt, "Toggle imported portrait sheets versus ASCII fallback faces.", () -> { options.importedPortraits=!options.importedPortraits; options.save(); sounds.play("portrait", options); logEvent("Imported portraits " + (options.importedPortraits?"enabled":"disabled") + "."); repaint(); }));
                buttons.add(new ButtonBox("LIGHTING: " + options.lightingFxLabel(), x+gap, y+rowStep*2, bw, bhOpt, "Cycle render-only visual lighting: off, static, or deterministic flicker plus bloom. Gameplay light remains turn-stable.", this::cycleLightingFx));
                buttons.add(new ButtonBox("REDUCED MOTION " + onOff(options.reducedMotion), x+gap*2, y+rowStep*2, bw, bhOpt, "Reduce nonessential animation motion while preserving gameplay feedback. Live flicker animation is subdued.", this::toggleReducedMotion));
                buttons.add(new ButtonBox("COLOR TARGET", x, y+rowStep*3, bw, bhOpt, "Select which UI color key is being edited.", this::cycleColorTarget));
                buttons.add(new ButtonBox("PALETTE: " + GameOptions.PALETTE_NAMES[options.colorPreset] + " ▼", x+gap, y+rowStep*3, bw, bhOpt, "Open the named color-preset dropdown and apply the selected palette globally.", () -> toggleGraphicsDropdown(2)));
                buttons.add(new ButtonBox("BRIGHT +", x+gap*2, y+rowStep*3, bw, bhOpt, "Brighten the currently selected color key.", () -> adjustSelectedColor(12)));
                buttons.add(new ButtonBox("BRIGHT -", x+gap*2, y+rowStep*4, bw, bhOpt, "Darken the currently selected color key.", () -> adjustSelectedColor(-12)));
                buttons.add(new ButtonBox("PAYLOAD: " + options.generatedAssetPayloadRootShortLabel(), x, y+rowStep*4, bw, bhOpt, "Select an external generated-art payload folder. Supports Phase B2/B3 exports or canonical assets/graphics/generated roots.", this::chooseGeneratedAssetPayloadRoot));
                buttons.add(new ButtonBox("F3 PERF " + onOff(options.diagnosticsOverlay), x+gap, y+rowStep*4, bw, bhOpt, "Toggle the F3 performance overlay: FPS, paint time, JVM memory, GC, render state, and lighting status.", this::togglePerformanceDiagnostics));
                buttons.add(new ButtonBox("CLEAR PAYLOAD", x+gap*2, y+rowStep*5, bw, bhOpt, "Clear the external generated-art payload root and fall back to bundled low_32 art.", this::clearGeneratedAssetPayloadRoot));
                addGraphicsDropdownButtons(x, y, bw, gap);
            } else if (optionsTab == 5) {
                buttons.add(new ButtonBox("PROFILE: " + jvmRuntimeProfile.targetLabel(), x, y, bw, bhOpt, "Cycle Launcher, Client Graphics, Thin Client, and Headless Server JVM profiles.", this::cycleJvmRuntimeProfile));
                buttons.add(new ButtonBox("GC: " + jvmRuntimeProfile.gc.label, x+gap, y, bw, bhOpt, "Cycle the saved garbage collector profile. Requires restart to apply.", this::cycleJvmGarbageCollector));
                buttons.add(new ButtonBox("PIPELINE: " + jvmRuntimeProfile.pipelineLabel(), x+gap*2, y, bw, bhOpt, "Cycle Java2D pipeline preference. Requires restart to fully apply.", this::cycleJvmPipelineProfile));
                buttons.add(new ButtonBox("RAM -", x, y+rowStep, bw, bhOpt, "Reduce max heap profile by 512 MB. Requires restart to apply.", () -> changeJvmMemory(-512)));
                buttons.add(new ButtonBox("RAM +", x+gap, y+rowStep, bw, bhOpt, "Increase max heap profile by 512 MB. Requires restart to apply.", () -> changeJvmMemory(512)));
                buttons.add(new ButtonBox("STRING DEDUPE " + onOff(jvmRuntimeProfile.stringDeduplication), x+gap*2, y+rowStep, bw, bhOpt, "Toggle string deduplication when supported by the selected collector. Requires restart.", this::toggleJvmStringDeduplication));
                buttons.add(new ButtonBox("TRANS BLIT " + onOff(jvmRuntimeProfile.transparentAcceleration), x, y+rowStep*2, bw, bhOpt, "Toggle transparent Java2D blit acceleration flag for graphical profiles. Requires restart.", this::toggleJvmTransparentAcceleration));
                buttons.add(new ButtonBox("NOAA " + onOff(jvmRuntimeProfile.disableVectorAntialiasing), x+gap, y+rowStep*2, bw, bhOpt, "Toggle Java2D vector antialias suppression for sharper/cheaper primitive graphics. Text hints remain separate.", this::toggleJvmNoAa));
                buttons.add(new ButtonBox("ACCEPT + RESTART", x+gap*2, y+rowStep*2, bw, bhOpt, "Save JVM profile and restart the current launcher/client process with the compiled flags.", this::acceptJvmSettingsAndRestart));
            } else if (optionsTab == 6) {
                buttons.add(new ButtonBox("CVD: " + AccessibilityCompatibilityAuthority.cvdLabel(options.cvdModeIndex), x, y, bw, bhOpt, "Cycle render-side color vision correction. Applies to the composited Java2D backbuffer only.", this::cycleCvdMode));
                buttons.add(new ButtonBox("HIGH CONTRAST " + onOff(options.highContrastText), x+gap, y, bw, bhOpt, "Toggle stronger text contrast containers for dense custom-canvas UI.", this::toggleHighContrastText));
                buttons.add(new ButtonBox("INSTANT TEXT " + onOff(options.instantDialogueText), x+gap*2, y, bw, bhOpt, "Disable typewriter/scrolled conversation text where that text path supports it.", this::toggleInstantDialogueText));
                buttons.add(new ButtonBox("SHAKE -", x, y+rowStep, bw, bhOpt, "Reduce screen-shake intensity by 10 percent.", () -> adjustScreenShake(-10)));
                buttons.add(new ButtonBox("SHAKE +", x+gap, y+rowStep, bw, bhOpt, "Increase screen-shake intensity by 10 percent.", () -> adjustScreenShake(10)));
                buttons.add(new ButtonBox("NARRATE", x+gap*2, y+rowStep, bw, bhOpt, "Push the current screen summary through the Swing AccessibleContext channel.", this::pushCurrentScreenNarration));
            } else if (optionsTab == 7) {
                buttons.add(new ButtonBox("SUBTITLES " + onOff(options.subtitlesEnabled), x, y, bw, bhOpt, "Toggle subtitles. Defaults on so dialogue text is available immediately.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleSubtitles(options))));
                buttons.add(new ButtonBox("SKIP SPLASH " + onOff(options.skipRepeatLogoSplashes), x+gap, y, bw, bhOpt, "Skip repeat logo/splash waits after first launch where the boot flow supports it.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleSkipSplashes(options))));
                buttons.add(new ButtonBox("AUTO LOOT " + onOff(options.autoLootEnabled), x+gap*2, y, bw, bhOpt, "Toggle automatic pickup preference for eligible safe drops.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleAutoLoot(options))));
                buttons.add(new ButtonBox("GHOST BUILD " + onOff(options.omniDirectionalGhostBuild), x, y+rowStep, bw, bhOpt, "Allow reasonable-distance blueprint placement without pixel-perfect corner standing.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleOmniGhostBuild(options))));
                buttons.add(new ButtonBox("HOLD BUILD " + onOff(options.holdToRepeatConstruction), x+gap, y+rowStep, bw, bhOpt, "Use hold-to-repeat construction where the build tool path supports repeated placement.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleHoldRepeatBuild(options))));
                buttons.add(new ButtonBox("SMART STORAGE " + onOff(options.smartStorageFilters), x+gap*2, y+rowStep, bw, bhOpt, "Enable smart storage/filter defaults for dump-all and routed logistics surfaces.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleSmartStorage(options))));
                buttons.add(new ButtonBox("PROXY CRAFT " + onOff(options.proxyCraftingFromLinkedStorage), x, y+rowStep*2, bw, bhOpt, "Prefer linked-base and nearby storage resources when recipe UIs support proxy counting.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleProxyCrafting(options))));
                buttons.add(new ButtonBox("WARN BLOCKS " + onOff(options.productionBlockerWarnings), x+gap, y+rowStep*2, bw, bhOpt, "Show clear reasons for blocked machines, scarce resources, and stalled recipes where known.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleProductionWarnings(options))));
                buttons.add(new ButtonBox("MARKET ALERT " + onOff(options.economicDisruptionAlerts), x+gap*2, y+rowStep*2, bw, bhOpt, "Enable macro-economic and supply-chain disruption alert preferences.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleMarketAlerts(options))));
                buttons.add(new ButtonBox("FAVOR LOCK " + onOff(options.favoredItemProtection), x, y+rowStep*3, bw, bhOpt, "Protect favored/marked gear from accidental scrap, sell, drop, or route decisions.", () -> applyQoL(GameplayQualityOfLifeAuthority.toggleFavoredProtection(options))));
                buttons.add(new ButtonBox("ITEM SAFETY: " + GameplayQualityOfLifeAuthority.protectionLabel(options.itemSafetyProfileIndex), x+gap, y+rowStep*3, bw, bhOpt, "Cycle item-safety strictness for low-durability, low-quality, mixed-stack, and worse-pickup warnings.", () -> applyQoL(GameplayQualityOfLifeAuthority.cycleItemSafetyProfile(options))));
                buttons.add(new ButtonBox("doom MODE " + onOff(options.doomModeEnabled), x+gap*2, y+rowStep*3, bw, bhOpt, "Highly experimental first-person 3D wrapper. Confirmation required before enabling.", this::requestDoomModeToggle));
                buttons.add(new ButtonBox("doom FOV -", x, y+rowStep*4, bw, bhOpt, "Narrow the first-person horizontal field of view.", () -> changeDoomFov(-5)));
                buttons.add(new ButtonBox("doom FOV " + Math.max(60, Math.min(110, options.doomModeFovDegrees)) + "°", x+gap, y+rowStep*4, bw, bhOpt, "Current doom mode horizontal field of view. Use the -/+ controls or brackets in-game.", () -> logEvent(firstPersonRenderViewport.statusLine(options))));
                buttons.add(new ButtonBox("doom FOV +", x+gap*2, y+rowStep*4, bw, bhOpt, "Widen the first-person horizontal field of view.", () -> changeDoomFov(5)));
                buttons.add(new ButtonBox("doom FOG: " + options.doomFogModeLabel(), x, y+rowStep*5, bw, bhOpt, "Switch first-person depth fog between perpendicular linear Z-depth and radial Euclidean distance.", this::cycleDoomFogMode));
                buttons.add(new ButtonBox("RENDER STRESS " + onOff(renderStressTest.active()), x+gap, y+rowStep*5, bw, bhOpt, "Flood the render path with synthetic particles, collisions, lightmaps, and ray intersections for profiling.", this::toggleRenderStressTest));
            }
            buttons.add(new ButtonBox("BACK", Math.max(24, w - 142), Math.max(24, h - 58), 118, 34, "Return to the prior menu.", () -> setScreen(previousScreen == Screen.PAUSE ? Screen.PAUSE : Screen.MENU)));
        } else if (screen == Screen.PAUSE) {
            int x=w/2-135, y=Math.min(h-312, Math.max(210, h/2-82));
            buttons.add(new ButtonBox("RESUME", x, y, 270, 44, "Return to the underhive.", () -> setScreen(Screen.GAME)));
            buttons.add(new ButtonBox("SAVE/LOAD", x, y+55, 270, 44, "Open expanded save/load slots and autosave state.", () -> openPanel(PanelMode.SAVELOAD)));
            buttons.add(new ButtonBox("LOAD", x, y+110, 270, 44, "Open manual and autosave load slots.", () -> loadGameSlot(AUTOSAVE_HOURLY_SLOT)));
            buttons.add(new ButtonBox("OPTIONS", x, y+165, 270, 44, "Open options.", () -> setScreen(Screen.OPTIONS)));
            buttons.add(new ButtonBox("MAIN MENU", x, y+220, 270, 44, "Abandon the current test run and return to main menu.", () -> setScreen(Screen.MENU)));
        } else if (screen == Screen.CAPTURE) {
            int x=w/2-165, y=h-128;
            buttons.add(new ButtonBox("ACKNOWLEDGE", x, y, 330, 44, "Close the custody report and return to the underhive after release.", () -> setScreen(Screen.GAME)));
        } else if (screen == Screen.LOST) {
            int x=w/2-165, y=h-128;
            buttons.add(new ButtonBox("LOAD", x, y, 155, 44, "Open the save/load menu. Manual and autosave slots are listed there.", () -> openPanel(PanelMode.SAVELOAD)));
            buttons.add(new ButtonBox("QUIT", x+175, y, 155, 44, "Return to the main menu.", () -> setScreen(Screen.MENU)));
        } else if (screen == Screen.PANEL) {
            if (panelUsesCommandSurface()) {
                Rectangle cmd = commandPanelRect();
                int bwBack = Math.max(110, Math.min(150, cmd.width - 28));
                buttons.add(new ButtonBox("BACK", cmd.x + 14, cmd.y + cmd.height - 48, bwBack, 34, "Return to active game screen.", this::closePanel));
            } else {
                buttons.add(new ButtonBox("BACK", 20, 20, 110, 38, "Return to active game screen.", this::closePanel));
            }
            if (panelMode == PanelMode.INFOPEDIA) {
                addInfopediaButtons();
            } else if (panelMode == PanelMode.LOOK) {
                Rectangle cmd = commandPanelRect();
                int bx = cmd.x + 14;
                int by = cmd.y + 64;
                int bw = Math.max(120, cmd.width - 28);
                buttons.add(new ButtonBox("EXAMINE", bx, by, bw, 36, "Open a focused reading of the selected visible person, fixture, object, or tile.", this::examineSelectedLookTarget));
                NpcEntity pet = selectedLookNpc();
                if (pet != null && pet.isPetActor()) {
                    buttons.add(new ButtonBox("PET", bx, by + 44, bw, 36, "Offer a gentle pet interaction if the companion animal is close enough and calm.", this::petSelectedLookPet));
                }
            } else if (panelMode == PanelMode.INTERACT) {
                UiLayout L = uiLayout();
                int bx = L.command.x + 14;
                int by = L.command.y + 64;
                int bw = Math.max(120, L.command.width - 28);
                buttons.add(new ButtonBox("CONFIRM", bx, by, bw, 36, "Confirm the selected adjacent interaction and spend the listed time.", this::confirmInteraction));
                by += 44;
                if (canScavengeFromCurrentRoom()) {
                    buttons.add(new ButtonBox("SCAVENGE ROOM", bx, by, bw, 36, "Open targeted scavenging choices for this unclaimed room.", () -> openPanel(PanelMode.SCAVENGE)));
                    by += 44;
                }
                if (selectedInteractionIsCot()) {
                    buttons.add(new ButtonBox("SLEEP -", bx, by, bw, 36, "Reduce requested cot sleep duration by one hour.", () -> changePendingSleepHours(-1)));
                    by += 44;
                    buttons.add(new ButtonBox("SLEEP +", bx, by, bw, 36, "Increase requested cot sleep duration up to eight hours.", () -> changePendingSleepHours(1)));
                    by += 44;
                }
                if (selectedInteractionIsGovernor()) {
                    buttons.add(new ButtonBox("BRIBE GOVERNOR", bx, by, bw, 36, "Pay the sector governor's lavish audience fee and hope this seed's governor actually holds an off-world ticket.", this::bribeSectorGovernor));
                    by += 44;
                    buttons.add(new ButtonBox("ATTACK GOVERNOR", bx, by, bw, 36, "Attempt to kill the sector governor and loot the ticket if this governor has one. Guards will respond.", this::attackSectorGovernor));
                    by += 44;
                }
                if (selectedInteractionIsFactionJournal()) {
                    buttons.add(new ButtonBox("STEAL JOURNAL", bx, by, bw, 36, "Steal this faction leader journal as physical evidence. INN pays large bounties for these.", () -> stealFactionJournalAt(lookX, lookY)));
                    by += 44;
                }
                if (selectedInteractionCanSellJournalsToINN()) {
                    buttons.add(new ButtonBox("SELL JOURNALS", bx, by, bw, 36, "Sell stolen faction leader journals to the Concord News Network. Rank-one leader journals pay 5000 script.", this::sellLeaderJournalsToINN));
                    by += 44;
                }
                if (selectedInteractionIsBankTerminal()) {
                    buttons.add(new ButtonBox("OPEN ACCOUNT", bx, by, bw, 36, "Open an account at the selected bank if you can pay its fee.", this::openSelectedBankAccount));
                    by += 44;
                    buttons.add(new ButtonBox("DEPOSIT ALL", bx, by, bw, 36, "Deposit all carried Concord Script into the selected account.", this::depositAllToSelectedBank));
                    by += 44;
                    buttons.add(new ButtonBox("WITHDRAW 100", bx, by, bw, 36, "Withdraw up to 100 Concord Script from this account.", () -> withdrawFromSelectedBank(100)));
                    by += 44;
                    buttons.add(new ButtonBox("WITHDRAW ALL", bx, by, bw, 36, "Withdraw as much of this account balance as carry capacity permits.", () -> withdrawFromSelectedBank(Integer.MAX_VALUE)));
                    by += 44;
                    buttons.add(new ButtonBox("LOCKBOX JOB", bx, by, bw, 36, "Accept a noble-bank retrieval job for lockboxes, gold, or stock certificates stolen from a vault.", this::acceptBankLockboxContract));
                    by += 44;
                    buttons.add(new ButtonBox("TURN LOCKBOX", bx, by, bw, 36, "Turn in a matching lockbox, gold ingot, permit, or stock certificate for a noble-bank retrieval contract.", this::turnInBankLockboxContract));
                    by += 44;
                }
                if (selectedInteractionIsBankVault()) {
                    buttons.add(new ButtonBox("OPEN VAULT", bx, by, bw, 36, "Attempt to open/loot this bank vault using a manager keycard, vault key, or security tools. This can trigger alarms.", this::openSelectedBankVault));
                    by += 44;
                }
                if (selectedInteractionIsBankAlarmPanel()) {
                    buttons.add(new ButtonBox("TAMPER ALARM", bx, by, bw, 36, "Attempt to silence or disable this bank alarm panel before or during a vault intrusion.", this::tamperSelectedBankAlarmPanel));
                    by += 44;
                }
                if (selectedInteractionIsBankManager()) {
                    buttons.add(new ButtonBox("STEAL KEYCARD", bx, by, bw, 36, "Attempt to lift a bank manager keycard. Failure raises suspicion and may trigger bank security.", this::stealSelectedBankManagerKeycard));
                    by += 44;
                }
                if (selectedInteractionIsExplosiveObject()) {
                    buttons.add(new ButtonBox("DISARM EXPLOSIVE", bx, by, bw, 36, "Attempt to disarm and recover the selected planted explosive. Minimum one time unit.", () -> disarmExplosiveAt(lookX, lookY)));
                    by += 44;
                }
                if (selectedInteractionIsPersistentStockObject()) {
                    buttons.add(new ButtonBox("INSPECT STOCK", bx, by, bw, 36, "Inspect this contract/corpse/faction-stock container without transferring items.", this::inspectSelectedPersistentStockObject));
                    by += 44;
                    buttons.add(new ButtonBox("TAKE ALL", bx, by, bw, 36, "Transfer as many visible persistent container items as carry capacity allows.", this::takeAllSelectedPersistentStockObject));
                    by += 44;
                }
                if (selectedInteractionIsSectorRail()) {
                    buttons.add(new ButtonBox("USE OFF-WORLD TICKET", bx, by, bw, 36, "If you carry a genuine off-world ticket, present it at the rail authority and end the escape route successfully.", this::useOffworldTicketAtRail));
                    by += 44;
                    buttons.add(new ButtonBox("TAKE SECTOR RAIL", bx, by, bw, 36, "Abandon this sector and ride to a new generated sector. Bases, recruits, storage, businesses, and local heat are left behind.", this::takeSectorRailToNewSector));
                    by += 44;
                }

            } else if (panelMode == PanelMode.COMBAT) {
                Rectangle cmd = commandPanelRect();
                int bx = cmd.x + 14, by = cmd.y + 64, bw = Math.max(120, cmd.width - 28);
                buttons.add(new ButtonBox("CONFIRM ATTACK", bx, by, bw, 36, "Fire/strike at the red targeting reticle.", this::confirmCombatTarget));
                buttons.add(new ButtonBox("FIRE MODE", bx, by+44, bw, 36, "Cycle SNAP/AIMED/BURST for ranged weapons.", this::cycleFireMode));
                buttons.add(new ButtonBox("RELOAD", bx, by+88, bw, 36, "Reload the best carried ranged weapon from generic ammunition.", this::reloadCurrentRangedWeapon));
                buttons.add(new ButtonBox("THROW EXPLOSIVE", bx, by+132, bw, 36, "Throw the first carried grenade/explosive at the reticle. G is the keyboard shortcut.", this::throwSelectedExplosiveAtCursor));
            } else if (panelMode == PanelMode.SCAVENGE) {
