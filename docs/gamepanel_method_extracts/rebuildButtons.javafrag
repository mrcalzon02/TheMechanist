            int bh = Math.max(17, Math.min(23, (available - gap * Math.max(0, commandCount - 1)) / Math.max(1, commandCount)));
            buttons.add(new ButtonBox("ZONE: " + auditZoneType().label + " ▼", bx, by, bw, bh, "Open the Zone Audit generation-profile selector.", () -> { auditZoneDropdownOpen = !auditZoneDropdownOpen; repaint(); })); by += bh + gap;
