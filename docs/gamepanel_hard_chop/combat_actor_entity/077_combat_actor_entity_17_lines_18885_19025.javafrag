    ArrayList<String> npcProductionLines() {
        seedNpcFactionProductionSites();
        ArrayList<String> lines = new ArrayList<>();
        for (NpcFactionSite site : npcFactionSites) lines.add("  " + site.summaryLine());
        return lines;
    }

