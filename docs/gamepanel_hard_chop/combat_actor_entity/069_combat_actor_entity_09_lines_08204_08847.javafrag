    ArrayList<FactionRecipeVariant> visibleGeneratedProductionJobs() {
        ArrayList<FactionRecipeVariant> all = ControlledProductionJobAuthority.visibleJobs(this, 240);
        selectedGeneratedProductionJobIndex = Math.max(0, Math.min(selectedGeneratedProductionJobIndex, Math.max(0, all.size()-1)));
        return all;
    }

    FactionRecipeVariant selectedGeneratedProductionJob() {
        ArrayList<FactionRecipeVariant> jobs = visibleGeneratedProductionJobs();
        if (jobs.isEmpty()) return null;
        return jobs.get(Math.max(0, Math.min(selectedGeneratedProductionJobIndex, jobs.size()-1)));
    }

