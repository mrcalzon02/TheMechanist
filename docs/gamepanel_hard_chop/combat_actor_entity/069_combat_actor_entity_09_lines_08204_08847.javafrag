    String contractBoardLine(Faction f) {
        FactionContract b = activeContractFor(f, "BOUNTY");
        FactionContract q = activeContractFor(f, "FETCH");
        return "Contracts: bounty " + (b == null ? "available" : b.shortLine()) + "; fetch " + (q == null ? "available" : q.shortLine()) + ". One of each may be active per faction.";
    }

    Faction activeRepFaction() {
        if (activeConversationNpc != null && activeConversationNpc.faction != Faction.NONE) return activeConversationNpc.faction;
        if (lastContractFaction != null && lastContractFaction != Faction.NONE) return lastContractFaction;
        return nearestFactionForRepresentative();
    }

    FactionContract activeContractFor(Faction f, String type) {
        for (FactionContract c : factionContracts) if (!c.completed && c.faction == f && c.type.equals(type)) return c;
        return null;
    }
