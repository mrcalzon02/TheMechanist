    void maybeUnlockKnowledgeFromItem(String item) {
        if (item == null) return;
        String low = item.toLowerCase(Locale.ROOT);
        if (low.contains("data slate") || low.contains("dataslate") || low.contains("technical manual")) {
            if (!hasKnowledge("Scavenged Schematics")) { unlockKnowledge("Scavenged Schematics"); logEvent("KNOWLEDGE DISCOVERED: Scavenged Schematics from " + item + "."); }
            gainXp("Knowledge", 2, "studying " + item);
        }
    }

// ... omitted 37 non-method/source lines between cataloged methods ...

    int unconsciousItemLoss() {
        if (inventory.isEmpty()) return 0;
        int target = Math.max(0, (int)Math.floor(inventory.size() * 0.10));
        if (inventory.size() >= 5) target = Math.max(1, target);
        target = Math.min(target, Math.max(0, inventory.size() / 3));
        int lost = 0;
        for (int i=0; i<target && !inventory.isEmpty(); i++) {
            int idx = rng.nextInt(inventory.size());
            String removed = removeInventoryAtWithTrace(idx);
            if (removed != null) lost++;
        }
        return lost;
    }
