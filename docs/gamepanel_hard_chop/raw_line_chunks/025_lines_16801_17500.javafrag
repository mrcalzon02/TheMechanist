        if (summary == null || summary.isEmpty()) summary = pendingInteractionSummary;
        lines.add("Preflight: " + pendingInteractionSummary);
        if (!summary.equals(pendingInteractionSummary)) lines.add("Context: " + summary);
        lines.add("Move cursor: WASD/Arrows | Confirm: far-right command button/Enter | Leave: ESC");
        g.setFont(smallFont);
        g.setColor(optionColor(GameOptions.TEXT_MAIN));
        drawClippedWrappedLines(g, lines, x + 14, y + 46, w - 28, h - 58, smallFont, false);
    }

    String hoveredButtonDescription() {
        for (ButtonBox b : buttons) if (b.contains(mouseX, mouseY)) return b.tip;
        return null;
    }


    int countInventory(String item) { return countContainerItems(CONTAINER_PLAYER_INVENTORY, inventory, item); }

int countContainerItems(String containerId, ArrayList<String> legacyList, String item) {
        if (item == null) return 0;
        ContainerRecord c = itemContainers.get(containerId);
        if (c != null && !c.itemInstanceIds.isEmpty()) {
            int n = 0;
            for (String id : c.itemInstanceIds) {
                ItemInstance inst = itemInstances.get(id);
                if (inst != null && ItemQuality.namesMatch(inst.displayName, item)) n++;
            }
            return n;
        }
        int n=0; for (String s: legacyList) if (ItemQuality.namesMatch(s, item)) n++; return n;
