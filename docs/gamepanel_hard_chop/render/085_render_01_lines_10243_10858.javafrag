    void renderGameSurface(Graphics2D g) {
        drawBackground(g);
        scrollRegions.clear();
        rebuildButtons();
        clampButtonsToVisibleMenuBounds();
        applySemanticButtonIcons();
        assignButtonDebugIds();
        if (screen == Screen.BOOT) drawBoot(g);
        else if (screen == Screen.LOADING) drawLoading(g);
        else if (screen == Screen.MENU) drawMenu(g);
        else if (screen == Screen.MODS) drawModsSurface(g);
            else if (screen == Screen.EDITOR) drawInGameEditorSurface(g);
        else if (screen == Screen.MULTIPLAYER) drawMultiplayerSurface(g);
        else if (screen == Screen.SECTOR_AUDIT) drawSectorAuditSurface(g);
        else if (screen == Screen.WORLD_SELECT) drawWorldSelect(g);
        else if (screen == Screen.WORLD_SETUP) drawWorldSetup(g);
        else if (screen == Screen.CHARACTER) drawCharacter(g);
        else if (screen == Screen.KNOWLEDGE) drawKnowledgeScreen(g);
        else if (screen == Screen.INTRO_CRAWL) drawIntroCrawl(g);
        else if (screen == Screen.GAME) {
            drawGame(g);
            renderNormalModeVisualJuice(g);
            firstPersonRenderViewport.render(g, this);
        }
        else if (screen == Screen.PAUSE) drawPause(g);
        else if (screen == Screen.PANEL) drawPanel(g);
        else if (screen == Screen.ZONE_SPLASH) drawZoneSplash(g);
        else if (screen == Screen.CAPTURE) drawCaptureScreen(g);
        else if (screen == Screen.LOST) drawLostScreen(g);
        else drawOptions(g);
        if (options.screenSaver && screen != Screen.BOOT && screen != Screen.LOADING && System.currentTimeMillis() - lastInputMillis > 15L*60L*1000L) drawIdleScreensaver(g);
        if (eulaGateActive) drawEulaOverlay(g);
        int hoverButtonIndex = activeHoverButtonIndex();
        for (int i=0;i<buttons.size();i++) buttons.get(i).draw(g, uiFont, i==selectedButton || i==hoverButtonIndex, images, options);
        drawHoverHelp(g, hoverButtonIndex);
        // Modal/profile/info alerts must sit above menu buttons, not beneath them.
        drawTimedAlert(g);
    }


    void renderNormalModeVisualJuice(Graphics2D g) {
        if (g == null) return;
        int w = Math.max(1, getWidth());
        int h = Math.max(1, getHeight());
        normalParticleEmitter.update(1.0f / 30.0f);
        normalParticleEmitter.render(g);
        normalLightmapRenderer.renderSingleWarmLight(g, w, h, Math.max(24, w / 2f), Math.max(24, h - 58f), 130f, 0.75f);
        renderStressTest.updateAndRender(g, this, w, h);
        if (options != null && options.doomModeEnabled) sharedHudOverlay.renderHUD(g, PlayerState.fromPanel(this), w, h);
    }

    void drawBackground(Graphics2D g) {
        int w=getWidth(), h=getHeight();
        g.setColor(new Color(7,7,9)); g.fillRect(0,0,w,h);
        g.setColor(new Color(20,20,18));
        for (int y=0;y<h;y+=32) g.drawLine(0,y,w,y);
        g.setColor(new Color(38,31,23));
        for (int x=0;x<w;x+=84) g.drawLine(x,0,x-30,h);
        drawGuiChrome(g);
    }

    void drawGuiChrome(Graphics2D g) {
        int w = getWidth(), h = getHeight();
        // GUI AUTHORITY PASS 0.8.7:
        // Only the root game window owns the cogitator_frame_0536 outer frame.
        // Sub-panels must draw their own inner bezel only when they actually exist,
        // preventing persistent stacked chrome from accumulating behind menus.
        drawSlicedFrame(g, 14, 14, w-28, h-28, "outer");
    }

    void drawSlicedFrame(Graphics2D g, int x, int y, int w, int h, String kind) {
        if (images.hasFrameSlices()) {
            BufferedImage tl = images.get("corner_top_left"), tr = images.get("corner_top_right"), bl = images.get("corner_bottom_left"), br = images.get("corner_bottom_right");
            BufferedImage t = images.get(kind.equals("inner") ? "inner_bezel_t" : "top_rail_left_mid");
            BufferedImage b = images.get(kind.equals("inner") ? "inner_bezel_b" : "bottom_rail_left_mid");
            BufferedImage l = images.get(kind.equals("inner") ? "inner_bezel_l" : "left_column_mid");
            BufferedImage r = images.get(kind.equals("inner") ? "inner_bezel_r" : "right_column_mid");
            BufferedImage c = images.get("inner_display_center");
            int cs = kind.equals("inner") ? 18 : 32;
            g.setColor(new Color(4,5,5, kind.equals("inner") ? 150 : 210));
            g.fillRect(x+cs, y+cs, Math.max(1,w-cs*2), Math.max(1,h-cs*2));
            if (c != null) RenderImageScaleCacheAuthority.draw(g, c, x+cs, y+cs, w-cs*2, h-cs*2);
            tileImage(g, t, x+cs, y, w-cs*2, cs);
            tileImage(g, b, x+cs, y+h-cs, w-cs*2, cs);
            tileImage(g, l, x, y+cs, cs, h-cs*2);
            tileImage(g, r, x+w-cs, y+cs, cs, h-cs*2);
            if (tl != null) RenderImageScaleCacheAuthority.draw(g, tl, x, y, cs, cs);
            if (tr != null) RenderImageScaleCacheAuthority.draw(g, tr, x+w-cs, y, cs, cs);
            if (bl != null) RenderImageScaleCacheAuthority.draw(g, bl, x, y+h-cs, cs, cs);
            if (br != null) RenderImageScaleCacheAuthority.draw(g, br, x+w-cs, y+h-cs, cs, cs);
        } else {
            g.setColor(new Color(30,25,18,210)); g.fillRect(x,y,w,h);
            g.setColor(new Color(120,92,52)); g.drawRect(x,y,w,h);
            g.setColor(new Color(62,50,32)); g.drawRect(x+3,y+3,w-6,h-6);
        }
        stampUiFrameId(g, "F", kind, x, y, w, h);
    }

    void tileImage(Graphics2D g, BufferedImage img, int x, int y, int w, int h) {
        if (img == null || w <= 0 || h <= 0) return;
        int stepW = Math.max(1, Math.min(w, img.getWidth()));
        int stepH = Math.max(1, Math.min(h, img.getHeight()));
        for (int yy=y; yy<y+h; yy+=stepH) {
            for (int xx=x; xx<x+w; xx+=stepW) {
                int dw = Math.min(stepW, x+w-xx), dh = Math.min(stepH, y+h-yy);
                RenderImageScaleCacheAuthority.draw(g, img, xx, yy, dw, dh);
            }
        }
    }

