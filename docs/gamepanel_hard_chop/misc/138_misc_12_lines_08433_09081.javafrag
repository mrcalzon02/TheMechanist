    void preflightLatestManualHaulContract() {
        String result = LogisticsHaulFulfillmentPreflightAuthority.createPreflight(this);
        lastLogisticsHaulPreflightReport = result;
        logEvent(result);
        DebugLog.audit("LOGISTICS_HAUL_FULFILLMENT_PREFLIGHT", result + " state=" + stateSummary());
        repaint();
    }

    void checkLatestLogisticsContractLifecycle() {
        String result = LogisticsContractLifecycleAuthority.checkLatestContract(this);
        lastLogisticsContractLifecycleReport = result;
        logEvent(result);
        DebugLog.audit("LOGISTICS_CONTRACT_LIFECYCLE", result + " state=" + stateSummary());
        repaint();
    }

    void cancelLatestLogisticsHaulContract() {
        String result = LogisticsContractLifecycleAuthority.cancelLatestContract(this, "player cancellation from Workbench");
        lastLogisticsContractLifecycleReport = result;
        logEvent(result);
        DebugLog.audit("LOGISTICS_CONTRACT_CANCEL", result + " state=" + stateSummary());
        repaint();
    }

    void executeLatestManualHaulContract() {
        String result = LogisticsManualHaulExecutionAuthority.executeLatestContract(this);
        lastLogisticsHaulExecutionReport = result;
        logEvent(result);
        DebugLog.audit("LOGISTICS_MANUAL_HAUL_EXECUTION", result + " state=" + stateSummary());
        repaint();
    }

    void moveWorkerMachineSelection(int delta) {
        ArrayList<BaseObject> ms = recruitOperableMachines();
        if (ms.isEmpty()) { logEvent("Machine selection failed: no recruit-operable base machines exist."); return; }
        selectedWorkerMachineIndex = Math.max(0, Math.min(ms.size()-1, selectedWorkerMachineIndex + delta));
        BaseObject m = ms.get(selectedWorkerMachineIndex);
        logEvent("Selected production machine: " + m.name + " [" + m.qualityName + "] assigned recipe=" + (m.assignedRecipe == null || m.assignedRecipe.isBlank() ? "none" : m.assignedRecipe) + ".");
        repaint();
    }

