    String firstAvailableRecruitName() {
        for (RecruitWorker r : factionRecruits) if (r != null && !"security".equalsIgnoreCase(r.duty)) return r.name;
        return factionRecruits.isEmpty() ? "unmanned" : factionRecruits.get(0).name;
    }

