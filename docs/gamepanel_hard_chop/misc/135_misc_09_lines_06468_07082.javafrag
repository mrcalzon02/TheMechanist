    int countMoney() { return Math.max(0, carriedScript); }
    int countBaseStoredScript() { return Math.max(0, baseStashedScript); }
    int countDataSpikes() { return countInventory("Data spike"); }
    boolean consumeDataSpike() { return removeInventoryOne("Data spike"); }
    void addImperialScript(int amount) { if (amount > 0) carriedScript = Math.min(Integer.MAX_VALUE - amount, Math.max(0, carriedScript)) + amount; }
    boolean spendImperialScript(int amount) {
        if (amount <= 0) return true;
        if (countMoney() < amount) return false;
        carriedScript = Math.max(0, carriedScript - amount);
        return true;
    }

    int migratePhysicalScriptFromList(ArrayList<String> list) {
        if (list == null || list.isEmpty()) return 0;
        int n = 0;
        for (int i=list.size()-1; i>=0; i--) {
            if ("Concord Script".equalsIgnoreCase(String.valueOf(list.get(i)))) { list.remove(i); n++; }
        }
        return n;
    }

    void purgePhysicalScriptInstances(String reason) {
        ArrayList<String> removeIds = new ArrayList<>();
        for (ItemInstance inst : itemInstances.values()) {
            if (inst != null && "Concord Script".equalsIgnoreCase(inst.displayName)) removeIds.add(inst.id);
        }
        if (!removeIds.isEmpty()) {
            for (String id : removeIds) itemInstances.remove(id);
            for (ContainerRecord c : itemContainers.values()) if (c != null) c.itemInstanceIds.removeAll(removeIds);
            DebugLog.audit("SCRIPT_INSTANCE_PURGE", "removed=" + removeIds.size() + " reason=" + reason + " state=" + stateSummary());
        }
    }

    void migrateLegacyPhysicalScript(String reason) {
        int inv = migratePhysicalScriptFromList(inventory);
        int base = migratePhysicalScriptFromList(baseStorage);
        if (inv > 0) carriedScript += inv;
        if (base > 0) baseStashedScript += base;
        if (inv + base > 0) DebugLog.audit("SCRIPT_MIGRATION", "inventory=" + inv + " base=" + base + " reason=" + reason + " state=" + stateSummary());
        purgePhysicalScriptInstances("legacy physical script migration: " + reason);
    }

    int currentInnDay() { return Math.max(0, turn / Math.max(1, TURNS_PER_HOUR * HOURS_PER_DAY)); }

