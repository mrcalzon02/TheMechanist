    BufferedImage currentOperatorPortraitIcon() {
        try {
            Optional<NameLockedProfilePortraitAuthority.Entry> preferred = NameLockedProfilePortraitAuthority.match(resolveOperatorProfileName());
            if (preferred.isPresent()) {
                BufferedImage img = images.getNameLockedProfilePortrait(preferred.get().key);
                if (img != null) return img;
            }
            FallbackProfileManagementAuthority.LocalProfile p = FallbackProfileManagementAuthority.loadOrCreate(userProfile);
            if (p != null) return images.getPortrait(0, p.portraitIndex);
        } catch (Throwable ignored) {}
        return images.getPortrait(0, 0);
    }

    LauncherShellStateAuthority.RouteDescriptor launcherProfileRoute(java.util.List<LauncherShellStateAuthority.RouteDescriptor> routes) {
        if (routes != null) {
            for (LauncherShellStateAuthority.RouteDescriptor route : routes) {
                if (route != null && route.route == LauncherShellStateAuthority.Route.PROFILE) return route;
            }
        }
        return new LauncherShellStateAuthority.RouteDescriptor(LauncherShellStateAuthority.Route.PROFILE, "PROFILE", "Open the active operator identity.", false);
    }

