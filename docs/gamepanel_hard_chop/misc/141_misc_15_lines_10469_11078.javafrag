    void openModsLauncherSurface() {
        logEvent(launcherShell.activate(LauncherShellStateAuthority.Route.MODS, "main menu mods/tools"));
        String body = launcherRuntime.openModsSurface();
        logEvent(body);
        setScreen(Screen.MODS);
        repaint();
    }

    void openSimulationEditorSuite() {
        inGameEditorStatus = "Editor opened inside the main game surface; no external JFrame/Dialog was launched.";
        DebugLog.audit("INGAME_SIMULATION_EDITOR", "opened " + inGameEditorRepository.auditLine());
        setScreen(Screen.EDITOR);
        repaint();
    }

