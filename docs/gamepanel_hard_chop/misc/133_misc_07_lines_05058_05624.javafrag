    void addLightLevelSource(int sx, int sy, int radius, int intensity, Color color) {
        if (world == null || lightLevelTiles == null || !world.inBounds(sx, sy)) return;
        int r = Math.max(1, Math.min(12, radius));
        int power = Math.max(1, Math.min(100, intensity));
        for (int x=Math.max(0,sx-r); x<=Math.min(world.w-1,sx+r); x++) for (int y=Math.max(0,sy-r); y<=Math.min(world.h-1,sy+r); y++) {
            double dist = Math.hypot(x - sx, y - sy);
            if (dist > r + 0.001) continue;
            // End-point walls may be lit, but any tile behind a blocking wall remains dark.
            if (!hasLineOfSight(sx, sy, x, y)) continue;
            double norm = Math.max(0.0, Math.min(1.0, dist / Math.max(1.0, r)));
            double smooth = norm * norm * (3.0 - 2.0 * norm);
            double falloff = Math.max(0.0, (1.0 - smooth) * 0.82 + 0.18 / (1.0 + 2.0 * norm * norm));
            int add = (int)Math.round(power * falloff);
            if (add <= 0) continue;
            lightLevelTiles[x][y] = Math.max(lightLevelTiles[x][y], Math.min(100, add));
        }
    }

    int lightLevelAt(int x, int y) {
        ensureLightLevelCache();
        if (world == null || lightLevelTiles == null || x < 0 || y < 0 || x >= lightLevelTiles.length || y >= lightLevelTiles[0].length) return 0;
        return Math.max(0, Math.min(100, lightLevelTiles[x][y]));
    }

    String lightDescriptionAt(int x, int y) {
        int l = lightLevelAt(x, y);
        if (l >= 75) return "brightly lit";
        if (l >= 50) return "lit";
        if (l >= 30) return "dim";
        if (l >= 14) return "gloom";
        if (l > 0) return "dark";
        return "blackout";
    }

    boolean lightAllowsPlayerVision(int x, int y, int distance) {
        if (x == playerX && y == playerY) return true;
        int l = lightLevelAt(x, y);
        if (distance <= 1) return true;
        int threshold;
        switch(activeMotionStateIndex) {
            case MOTION_STATIONARY: threshold = 7; break;
            case MOTION_SNEAK: threshold = 10; break;
            case MOTION_WALK: threshold = 12; break;
            case MOTION_RUN: threshold = 18; break;
            case MOTION_SPRINT: threshold = 24; break;
            default: threshold = 12;
        }
        return l >= threshold;
    }

    int rangedDarknessPenalty(int x0, int y0, int x1, int y1) {
        int target = lightLevelAt(x1, y1);
        int origin = lightLevelAt(x0, y0);
        int p = 0;
        if (target < 12) p += 18;
        else if (target < 24) p += 10;
        else if (target < 40) p += 5;
        if (origin < 10) p += 4;
        if (origin >= 60 && target >= 40) p = Math.max(0, p - 4);
        return Math.max(0, Math.min(35, p));
    }

    int detectionLightPenalty(int observerX, int observerY, int targetX, int targetY) {
        int target = lightLevelAt(targetX, targetY);
        int observer = lightLevelAt(observerX, observerY);
        int penalty = 0;
        if (target < 8) penalty += 20;
        else if (target < 18) penalty += 12;
        else if (target < 32) penalty += 6;
        if (observer < 8) penalty += 4;
        if (target >= 65) penalty -= 6;
        return Math.max(0, Math.min(28, penalty));
    }

    int visionRange() { return Math.max(3, Math.min(18, 4 + stat("Vision", 6) / 2 + motionVisionModifier() + activePortableLightVisionBonus())); }
    int detailVisionRange() { return Math.max(1, Math.min(11, 2 + stat("Vision", 6) / 3 + motionDetailVisionModifier() + Math.max(0, activePortableLightVisionBonus()/2))); }
    int hearingRange() { return Math.max(3, Math.min(22, 5 + stat("Hearing", 6) + motionHearingModifier())); }

    int facingDx() { return lastMoveDx == 0 && lastMoveDy == 0 ? 1 : Integer.compare(lastMoveDx, 0); }
    int facingDy() { return lastMoveDx == 0 && lastMoveDy == 0 ? 0 : Integer.compare(lastMoveDy, 0); }

    String facingLabel() {
        int fx = facingDx(), fy = facingDy();
        if (fx > 0) return "E";
        if (fx < 0) return "W";
        if (fy > 0) return "S";
        if (fy < 0) return "N";
        return "E";
    }

    double visionForwardRadius() {
        int vr = visionRange();
        switch(activeMotionStateIndex) {
            case MOTION_STATIONARY: return vr + 1.0;
            case MOTION_SNEAK: return Math.max(3, vr - 0.5);
            case MOTION_WALK: return vr + 1.0;
            case MOTION_RUN: return Math.max(3, vr * 0.92);
            case MOTION_SPRINT: return Math.max(3, vr * 0.82);
            default: return vr;
        }
    }

    double visionSideRadius() {
        int vr = visionRange();
        switch(activeMotionStateIndex) {
            case MOTION_STATIONARY: return Math.max(3, vr * 0.92);
            case MOTION_SNEAK: return Math.max(2.5, vr * 0.62);
            case MOTION_WALK: return Math.max(3, vr * 0.75);
            case MOTION_RUN: return Math.max(2, vr * 0.45);
            case MOTION_SPRINT: return Math.max(1.5, vr * 0.32);
            default: return Math.max(2, vr * 0.7);
        }
    }

    double visionRearRadius() {
        int vr = visionRange();
        switch(activeMotionStateIndex) {
            case MOTION_STATIONARY: return Math.max(3, vr * 0.75);
            case MOTION_SNEAK: return Math.max(2, vr * 0.52);
            case MOTION_WALK: return Math.max(2, vr * 0.55);
            case MOTION_RUN: return Math.max(1.5, vr * 0.25);
            case MOTION_SPRINT: return Math.max(1.0, vr * 0.15);
            default: return Math.max(2, vr * 0.45);
        }
    }

    boolean inPlayerVisionShape(int x, int y) {
        if (x == playerX && y == playerY) return true;
        int dx = x - playerX, dy = y - playerY;
        int fx = facingDx(), fy = facingDy();
        double forward = dx * fx + dy * fy;
        double side = Math.abs(dx * fy - dy * fx);
        if (forward >= 0) {
            double a = Math.max(1.0, visionForwardRadius());
            double b = Math.max(1.0, visionSideRadius());
            return (forward*forward)/(a*a) + (side*side)/(b*b) <= 1.0;
        } else {
            double a = Math.max(1.0, visionRearRadius());
            double b = Math.max(1.0, visionSideRadius() * 0.78);
            double rear = -forward;
            return (rear*rear)/(a*a) + (side*side)/(b*b) <= 1.0;
        }
    }

    boolean portableLightCacheDirty() {
        if (activePortableLightExpiresTurn > 0 && activePortableLightExpiresTurn <= turn) return true;
        for (PortableLightInstance l : portableLights) if (l != null && l.expiresTurn <= turn) return true;
        if (world != null && world.hasFlickeringLights() && lightingCacheTurn != turn) return true;
        return false;
    }

    int applyPortableLightVisibility() {
        if (world == null || visibleTiles == null || rememberedTiles == null) return 0;
        int added = 0;
        int r = activePortableLightRadius();
        if (r > 0) added += applyLightCircle(playerX, playerY, r, true);
        for (PortableLightInstance l : portableLights) {
            if (l == null || l.expiresTurn <= turn || !sameWorldLocation(l.worldKey)) continue;
            PortableLightProfile p = PortableLightProfile.profile(l.itemName);
            int rr = p == null ? l.radius : p.radius;
            added += applyLightCircle(l.x, l.y, rr, false);
        }
        return added;
    }

