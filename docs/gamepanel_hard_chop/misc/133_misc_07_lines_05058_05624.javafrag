    int stat(String name, int fallback) {
        if (active == null) return fallback;
        return active.stats.getOrDefault(name, fallback);
    }

    int activePortableLightRadius() {
        PortableLightProfile p = PortableLightProfile.profile(activePortableLightItem);
        if (p == null || activePortableLightExpiresTurn <= turn) return 0;
        return Math.max(0, p.radius);
    }

    int activePortableLightVisionBonus() {
        int r = activePortableLightRadius();
        if (r <= 0) return 0;
        return Math.max(1, Math.min(4, r / 2));
    }

    void markLocalDirtyRegion(String reason, int cx, int cy, int radius, boolean light, boolean noise, boolean vision, boolean hazard) {
        if (world == null) return;
        localDirtyTracker.mark(world, cx, cy, radius, light, noise, vision, hazard, reason);
        if (light) lightLevelCacheTurn = -999999;
        if (noise) world.noiseFieldTurn = -1;
        if (vision) { sensoryCacheX = Integer.MIN_VALUE; sensoryCacheWorld = null; }
        lastDirtyRegionReport = localDirtyTracker.summary();
    }

    void markPlayerNeighborhoodDirty(String reason) {
        markLocalDirtyRegion(reason, playerX, playerY, Math.max(6, visionRange()+2), true, true, true, false);
    }

    void ensureLightLevelCache() {
        if (world == null) return;
        boolean needs = lightLevelTiles == null || lightLevelCacheWorld != world || lightLevelTiles.length != world.w || lightLevelTiles[0].length != world.h || lightLevelCacheTurn != turn || localDirtyTracker.lightDirty(world);
        if (needs) rebuildLightLevelCache();
    }

