    Point oppositeEdgeSpawn(String dir, int tx, int ty) {
        if (world == null) return null;
        pendingTransitionReturnEdge = oppositeEdge(dir);
        // Carry the source door's axis coordinate across the boundary so the
        // destination can place the player beside the matching return doors,
        // not in an arbitrary edge-nearest room. Sewer travel intentionally
        // does not use this path; sewer exits remain the chaotic exception.
        return new Point(tx, ty);
    }

    String oppositeEdge(String dir) {
        if ("N".equals(dir)) return "S";
        if ("S".equals(dir)) return "N";
        if ("W".equals(dir)) return "E";
        if ("E".equals(dir)) return "W";
        return "";
    }

    void interactSewerHatch(int tx, int ty) {
        if (atlas == null || world == null) { logEvent("No sector atlas available for sewer hatch."); return; }
        if (atlas.sewer) { logEvent("This hatch logic is already on a sewer layer; use a ladder/drain marker instead."); return; }
        atlas.sewer = true;
        loadAtlasWorld("sewer hatch down to Floor " + atlas.floor + "B", null);
    }

    void interactSewerLadder(int tx, int ty) {
        if (atlas == null || world == null) { logEvent("No sector atlas available for sewer ladder."); return; }
        if (!atlas.sewer) { logEvent("This ladder/drain is not connected to a sewer layer from here."); return; }
        atlas.sewer = false;
        loadAtlasWorld("sewer ladder back to Floor " + atlas.floor, null);
    }

    void interactElevator(int tx, int ty) {
        if (atlas == null || world == null) { logEvent("No sector atlas available for elevator."); return; }
        if (atlas.floor >= 10) { logEvent("The elevator coughs against the upper limit of this sector stack. No higher route is mapped yet."); advanceTurn("tests a capped elevator."); return; }
        atlas.floor = Math.min(10, atlas.floor + 1);
        atlas.sewer = false;
        loadAtlasWorld("elevator ascent to Floor " + atlas.floor, null);
    }

