            case 'r': return "corpse loot container; persistent body inventory with provenance-bearing recoverables.";
            case 'D': return "double zone door at map edge; adjacent-zone transition.";
            case 'S': return "sewer hatch down to the B-layer beneath this floor.";
            case 'v': return "sewer ladder/drain transition between sewer layers and floor access.";
            case 'E': return "elevator shaft; vertical floor transition skipping sewer interlayers.";
            case 's': return "storage crate; claimed-base object.";
            case 'w': return "scrap workbench; claimed-base object.";
            case 'd': return "barricade; claimed-base defense object.";
            case 'c': return "sleeping cot; claimed-base object.";
            case 'u': return "water barrel; claimed-base object.";
            case 'a': return "alarm trap; claimed-base defense object.";
            case 'Y': return "Martian atmospheric water condenser room machine; inspectable imported EMM preview, usable for water extraction when unlocked/powered.";
            case 'J': return "Martian emergency assembler room machine; assembles designated components when unlocked/powered.";
            case 'B': return "Martian emergency boiler room machine; can produce clean water or be stripped for dirty water and fuel.";
            case 'K': return "Martian micro laboratorium room machine; research and sample analysis fixture.";
