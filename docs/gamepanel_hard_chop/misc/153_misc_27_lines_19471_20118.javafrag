    void markJvmProfileChanged(String message) {
        JvmRuntimeProfileAuthority.save(jvmRuntimeProfile);
        jvmRuntimeRestartPending = true;
        jvmRuntimeNotice = message + " Saved to settings/jvm_runtime.properties. Restart required for full effect.";
        logEvent(jvmRuntimeNotice);
        DebugLog.audit("JVM_RUNTIME_PROFILE", JvmRuntimeProfileAuthority.auditSummary(jvmRuntimeProfile));
        repaint();
    }

    void cycleJvmRuntimeProfile() {
        JvmRuntimeProfileAuthority.cycleTarget(jvmRuntimeProfile);
        markJvmProfileChanged("JVM runtime profile now " + jvmRuntimeProfile.targetLabel() + ".");
    }

    void cycleJvmGarbageCollector() {
        JvmRuntimeProfileAuthority.cycleGc(jvmRuntimeProfile);
        markJvmProfileChanged("JVM garbage collector profile now " + jvmRuntimeProfile.gc.label + ".");
    }

    void cycleJvmPipelineProfile() {
        JvmRuntimeProfileAuthority.cyclePipeline(jvmRuntimeProfile);
        markJvmProfileChanged("Java2D pipeline profile now " + jvmRuntimeProfile.pipelineLabel() + ".");
    }

    void changeJvmMemory(int deltaMb) {
        JvmRuntimeProfileAuthority.changeMemory(jvmRuntimeProfile, deltaMb);
        markJvmProfileChanged("JVM max heap profile now " + jvmRuntimeProfile.maxRamMb + " MB.");
    }

    void toggleJvmStringDeduplication() {
        jvmRuntimeProfile.stringDeduplication = !jvmRuntimeProfile.stringDeduplication;
        markJvmProfileChanged("JVM string deduplication " + (jvmRuntimeProfile.stringDeduplication ? "enabled" : "disabled") + ".");
    }

    void toggleJvmTransparentAcceleration() {
        jvmRuntimeProfile.transparentAcceleration = !jvmRuntimeProfile.transparentAcceleration;
        markJvmProfileChanged("Java2D transparent blit acceleration " + (jvmRuntimeProfile.transparentAcceleration ? "enabled" : "disabled") + ".");
    }

    void toggleJvmNoAa() {
        jvmRuntimeProfile.disableVectorAntialiasing = !jvmRuntimeProfile.disableVectorAntialiasing;
        markJvmProfileChanged("Java2D vector antialias suppression " + (jvmRuntimeProfile.disableVectorAntialiasing ? "enabled" : "disabled") + ".");
    }

    void acceptJvmSettingsAndRestart() {
        JvmRuntimeProfileAuthority.save(jvmRuntimeProfile);
        java.util.List<String> command = new ArrayList<>();
        String javaExe = Paths.get(System.getProperty("java.home", ""), "bin", isWindowsHost() ? "java.exe" : "java").toString();
        command.add(javaExe);
        command.addAll(jvmRuntimeProfile.buildJvmArgs());
        command.add("-cp");
        command.add(System.getProperty("java.class.path"));
        command.add(TheMechanist.class.getName());
        DebugLog.audit("JVM_RESTART", "Restarting with command=" + command);
        logEvent("Restarting with accepted JVM profile: " + jvmRuntimeProfile.targetLabel() + ".");
        try {
            new ProcessBuilder(command).inheritIO().start();
            shutdownRuntime();
            Window win = SwingUtilities.getWindowAncestor(this);
            if (win != null) win.dispose();
            System.exit(0);
        } catch (Throwable t) {
            DebugLog.error("JVM_RESTART", "Failed to restart with selected JVM profile.", t);
            jvmRuntimeNotice = "Restart failed: " + t.getMessage();
            logEvent(jvmRuntimeNotice);
            repaint();
        }
    }

    boolean isWindowsHost() { return System.getProperty("os.name", "").toLowerCase(Locale.ROOT).contains("win"); }

    void togglePerformanceDiagnostics() {
        String line = performanceDiagnostics.toggle();
        options.diagnosticsOverlay = performanceDiagnostics.visible();
        options.save();
        logEvent(line);
        DebugLog.audit("PERFORMANCE_DIAGNOSTICS", performanceDiagnostics.auditSummary());
        repaint();
    }
