    char selectedTile() { return SelectedContextSurfaceApi.selectedTile(world, lookCursorActive, lookX, lookY, playerX, playerY); }

    boolean isRestProp(char c) { return c=='b' || c=='h' || c=='n' || c=='q'; }

    void restOneHourOnUnclaimedFurniture(int tx, int ty, char tile) {
        int rid = world.roomIdAt(tx, ty);
        if (rid < 0 || isInClaimedRoom(tx, ty)) { logEvent("This rest spot is not an unclaimed public room feature."); return; }
        int chanceKick = 25 + Math.max(0, gangHeat/3) + (world.roomFaction(rid)==Faction.NONE ? 0 : 15);
        int roll = rng.nextInt(100);
        DebugLog.audit("PUBLIC_REST", "tile="+tile+" room="+rid+" kickChance="+chanceKick+" roll="+roll+" state="+stateSummary());
        showTimedAlert("YOU FELL ASLEEP IN PUBLIC!", "You curl up on unclaimed furniture for a desperate hour. Anyone passing by may decide this is their problem, your problem, or an opportunity.", 4200);
        for (int i=0;i<6;i++) advanceTurn("rests uneasily on unclaimed furniture.");
        if (roll < chanceKick) {
            fatigue = Math.min(25, fatigue + 1);
            logEvent("You try to rest for an hour, but someone kicks you out before it does much good. Fatigue +1 from interrupted sleep.");
        } else {
            int old = fatigue; fatigue = Math.max(0, fatigue - 1);
            logEvent("You steal one hour of rough rest on public furniture. Fatigue " + old + "->" + fatigue + ".");
        }
    }

    String selectedCoordText() { return SelectedContextSurfaceApi.selectedCoordText(lookCursorActive, lookX, lookY, playerX, playerY); }


    void openDepotTrader(int tx, int ty) {
        NpcEntity clerk = NpcEntity.tradeClerkFor(world == null ? ZoneType.NEUTRAL_RAIL_DEPOT : world.zoneType, tx, ty, rng);
        activeConversationNpc = clerk;
        activeConversationNpc = clerk;
        activeTrader = TraderSession.forNpc(clerk, world == null ? ZoneType.NEUTRAL_RAIL_DEPOT : world.zoneType, rng);
        activeTrader.sourceSite = siteForFaction(clerk.faction, world == null ? ZoneType.NEUTRAL_RAIL_DEPOT : world.zoneType);
        activeTrader.applyNpcSiteStock(activeTrader.sourceSite, rng, world, turn);
        materializeFactionTraderStock(activeTrader);
        activeTrader.applySupplyChainStock(world, turn, rng);
        selectedTradeOffer = 0;
        conversationBranch = clerk.name + ": Neutral counter acknowledged. Buy, sell, haggle, or ask after the pipes.";
        lastConversation = "Trade depot clerk opened conversation: " + conversationBranch;
        lastTradeReport = "Trade depot opened with " + clerk.name + ". Stock is zone appropriate; trader buys and sells.";
        logConversation("OPEN_DEPOT", conversationBranch);
        openPanel(PanelMode.TRADE);
    }
