    String fireModeLabel() {
        if (combatFireModeIndex < 0 || combatFireModeIndex >= FIRE_MODE_LABELS.length) combatFireModeIndex = 0;
        return FIRE_MODE_LABELS[combatFireModeIndex];
    }

    void cycleFireMode() {
        combatFireModeIndex = Math.floorMod(combatFireModeIndex + 1, FIRE_MODE_LABELS.length);
        lastTargetingReport = "Fire mode now " + fireModeLabel() + ".";
        sounds.play("tab", options);
    }

