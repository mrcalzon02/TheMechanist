    void resetPushPastIntent() {
        pushPastIntentNpcId = "";
        pushPastIntentX = Integer.MIN_VALUE;
        pushPastIntentY = Integer.MIN_VALUE;
        pushPastIntentDx = 0;
        pushPastIntentDy = 0;
        pushPastIntentCount = 0;
    }

